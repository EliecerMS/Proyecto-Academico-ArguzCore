                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="CodigoProyecto" />

                    <!-- Alert de Advertencia -->
                    <div class="alert alert-info mb-3">
                        <i class="fas fa-info-circle"></i>
                        <strong>Nueva Versión:</strong> Agregará una nueva versión a un documento existente.
                        La versión anterior quedará guardada en el historial y podrá ser consultada en cualquier momento.
                    </div>

                    <!-- Seleccionar Documento -->
                    <div class="mb-3">
                        <label class="form-label">
                            Seleccionar Documento 
                            <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" asp-for="DocumentoIdParaVersion" required id="selectDocumento">
                            <option value="">-- Seleccione un documento versionado --</option>
                            @foreach (var doc in Model.Documentos.Where(d => d.TipoDocumento == "Versionado").OrderBy(d => d.NombreDocumento))
                            {
                                <option value="@doc.IdDocumento">
                                    @doc.NombreDocumento (@doc.VersionActual) 
                                    @if (!string.IsNullOrEmpty(doc.CategoriaDocumento))
                                    {
                                        <text>- [@doc.CategoriaDocumento]</text>
                                    }
                                </option>
                            }
                        </select>
                        <small class="text-muted">
                           
                            Solo se muestran documentos con control de versiones
                        </small>
                    </div>

                    <!-- Archivo Nueva Versión -->
                    <div class="mb-3">
                        <label class="form-label">
                            Archivo de Nueva Versión 
                            <span class="text-danger">*</span>
                        </label>
                        <input type="file" 
                               class="form-control" 
                               asp-for="ArchivoNuevaVersion" 
                               required
                               accept=".pdf,.docx,.xlsx,.dwg,.dxf,.rvt,.jpg,.jpeg,.png,.zip" />
                        <small class="text-muted">
                           
                            Máximo 50 MB
                        </small>
                    </div>

                    <!-- Comentarios (OBLIGATORIO) -->
                    <div class="mb-3">
                        <label class="form-label">
                            Comentarios sobre los Cambios 
                            <span class="text-danger">*</span>
                        </label>
                        <textarea class="form-control" 
                                  asp-for="ComentariosNuevaVersion" 
                                  rows="3"
                                  required
                                  maxlength="1000"
                                  placeholder="Ej: Corrección de medidas en sección B, actualización de especificaciones técnicas, revisión de materiales"></textarea>
                        <small class="text-muted">
                            <strong>Importante:</strong> 
                            Describa claramente los cambios realizados en esta versión para mantener un historial comprensible
                        </small>
                    </div>

                    <!-- Info adicional -->
                    <div class="alert alert-info mb-0">
                        <i class="fas fa-info-circle"></i>
                        <strong>Numeración automática:</strong> El número de versión se incrementará automáticamente (ej: 1.0 → 1.1 → 2.0)
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-upload"></i> Guardar nueva versión
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Script para Alertas -->
    <script>
        //script que hace funcionar las alertas
        document.addEventListener('DOMContentLoaded', function() {
            // Mostrar todos los toasts que existan
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            var toastList = toastElList.map(function(toastEl) {
                return new bootstrap.Toast(toastEl, {
                    autohide: true,
                    delay: 3000  // 3 segundos
                });
            });

            // Activar cada toast
            toastList.forEach(toast => toast.show());
        });
    </script>
    
    <!-- Script de Modal Editar Tarea -->
    <script>
        var editarTareaModal = document.getElementById('editarTareaModal');
        editarTareaModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;

            // Extraer valores de los atributos data-*
            var id = button.getAttribute('data-id');
            var nombre = button.getAttribute('data-nombre');
            var descripcion = button.getAttribute('data-descripcion');
            var fechainicio = button.getAttribute('data-fechainicio');
            var fechafin = button.getAttribute('data-fechafin');

            // Asignar los valores a los inputs del modal
            editarTareaModal.querySelector('#edit-id').value = id;
            editarTareaModal.querySelector('#edit-nombre').value = nombre;
            editarTareaModal.querySelector('#edit-descripcion').value = descripcion;
            editarTareaModal.querySelector('#edit-fechainicio').value = fechainicio ? new Date(fechainicio).toISOString().slice(0, 10) : '';
            editarTareaModal.querySelector('#edit-fechafin').value = fechafin ? new Date(fechafin).toISOString().slice(0, 10) : '';

        });
        // Pasar el ID del usuario antiguo al modal de reasignación
        var modalReasignar = document.getElementById('modalReasignarPersonal');
        modalReasignar.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var antiguoId = button.getAttribute('data-antiguo');
            document.getElementById('UsuarioReasignar').value = antiguoId;
        });
        // Editar solicitud de material
    var modalEditarSolicitud = document.getElementById('editarSolicitudModal');
    modalEditarSolicitud.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;

        var id = button.getAttribute('data-id');
        var material = button.getAttribute('data-material');
        var cantidad = button.getAttribute('data-cantidad');
        var prioridad = button.getAttribute('data-prioridad');

        document.getElementById('editSolicitudId').value = id;
        document.getElementById('editMaterialId').value = material;
        document.getElementById('editCantidad').value = cantidad;
        document.getElementById('editPrioridad').value = prioridad;
    });
    </script>

    <!-- Script de Modal Editar Nota -->
    <script>
        var editarNotaModal = document.getElementById('editarNotaModal');
        editarNotaModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;

            // Extraer valores de los atributos data-*
            var idNota = button.getAttribute('data-id');
            var descripcion = button.getAttribute('data-descripcion');

            // Presentar el valores actuales en el textbox
            editarNotaModal.querySelector('#edit-IdNota').value = idNota;
            editarNotaModal.querySelector('#edit-Descripcion').value = descripcion;
        });
    </script>

    <!-- Script para Guardar Ultimo Tab -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var tabActiva = '@TempData["TabActiva"]';
            if(tabActiva) {
                var triggerEl = document.querySelector(`#nav-${tabActiva}`);
                if(triggerEl){
                    var tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
        });
    </script>

    <!-- Script de Modal Cerrar Incidente -->
    <script>
        var modalCerrarIncidente = document.getElementById('modalCerrarIncidente');
        modalCerrarIncidente.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var descripcion = button.getAttribute('data-descripcion');

            // asignar al hidden input y al texto
            modalCerrarIncidente.querySelector('#incidenteId').value = id;
            modalCerrarIncidente.querySelector('#descripcionIncidente').textContent = descripcion;
        });
    </script>

    <!-- Script de Modal Editar Incidente -->
    <script>
        var modalEditarIncidente = document.getElementById('modalEditarIncidente');
        modalEditarIncidente.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var descripcion = button.getAttribute('data-descripcion');

            document.getElementById('editIncidenteId').value = id;
            document.getElementById('editIncidenteDescripcion').value = descripcion;
        });
    </script>
    <script>
        var modalDisminuirMaterialObra = document.getElementById('modalDisminuiMaterial');
        modalDisminuirMaterialObra.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var idMaterialProyecto = button.getAttribute('data-idMaterialProyecto');
            var nombreMaterial = button.getAttribute('data-nombreMaterial');

            document.getElementById('MaterialDisminuir_IdMaterialProyecto').value = idMaterialProyecto;
            document.getElementById('nombreMaterialStrong').innerText = nombreMaterial;
        });
    </script>
    <script>
        var modalDevolverMaterialObra = document.getElementById('modalDevolverMaterial');
        modalDevolverMaterialObra.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var idMaterialDevolver = button.getAttribute('data-idMaterialDevolver');
            var nombreMaterial = button.getAttribute('data-nombreMaterialDevolver');
            var idMaterialProyecto = button.getAttribute('data-idMaterialProyectoDevolver');

            document.getElementById('MaterialDevolver_IdMaterial').value = idMaterialDevolver;
            document.getElementById('nombreMaterialDevolverStrong').innerText = nombreMaterial;
            document.getElementById('ProyectoMaterialIdDevolver').value = idMaterialProyecto;
        });
    </script>
    <script>
        var modalEliminarMaterialProyecto = document.getElementById('modalEliminarMaterialProyecto');
        modalEliminarMaterialProyecto.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var idMaterialEliminacionDevolver = button.getAttribute('data-idMaterialEliminacionDevolver');
            var nombreMaterial = button.getAttribute('data-nombreMaterialEliminar');
            var idMaterialProyecto = button.getAttribute('data-idMaterialProyectoEliminar');
            var cantidadMaterialEliminar = button.getAttribute('data-cantidadEliminarMaterial');

            document.getElementById('MaterialDevolverEliminar').value = idMaterialEliminacionDevolver;
            document.getElementById('nombreMaterialProyectoEliminarStrong').innerText = nombreMaterial;
            document.getElementById('ProyectoMaterialIdEliminar').value = idMaterialProyecto;
            document.getElementById('CantidadEliminarMaterialObra').value = cantidadMaterialEliminar;
            document.getElementById('CantidadEliminarMaterialObraStromg').innerText = cantidadMaterialEliminar;
        });
    </script>
}
