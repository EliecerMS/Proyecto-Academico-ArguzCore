@page
@model CleanArchIdentityDemo.WebUI.Pages.SupervisorProyectos.DetallesProyectoModel
@{
}
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 25px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" id="successToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" id="errorToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true" id="warningToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["WarningMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-info border-0" role="alert" aria-live="assertive" aria-atomic="true" id="infoToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-info-circle me-2"></i>
                    @TempData["InfoMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>
<!--Solamente a manera de prueba muestra el nombre y estado de proyecto  -->
@if (Model.DetalleProyecto != null)
{
    //<h1>@Model.DetalleProyecto.Nombre</h1>
    //<h1>@Model.DetalleProyecto.EstadoProyectoId</h1>
    <h2>Detalles del Proyecto - @Model.DetalleProyecto.Nombre</h2>
    <a asp-page="./ListaProyectos"><i class="fa-solid fa-arrow-left"></i> Volver a lista de proyectos </a>

}


<!--Boton para cambiar de estado el proyecto  -->
<button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#NuevoEstadoProyectoModal">
    Nuevo Estado
</button>

<!--Muestra un mensaje de exito cuando se cambie el estado  -->
@if (TempData["MensajeExito"] != null)
{
<div class="alert alert-success alert-dismissible fade show" role="alert">
    @TempData["MensajeExito"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}


@if (TempData["ErrorPersonal"] != null)
{
<div class="modal fade" id="modalErrorPersonal" tabindex="-1" aria-modal="true" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Aviso</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p>@TempData["ErrorPersonal"]</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var myModal = new bootstrap.Modal(document.getElementById('modalErrorPersonal'));
        myModal.show();
    });
</script>
}



<nav>
    <div class="nav nav-tabs" id="nav-tab" role="tablist">
        <button class="nav-link" id="nav-marcaEntradaSalida" data-bs-toggle="tab" data-bs-target="#nav-Marca-tab" type="button" role="tab" aria-controls="nav-Marca-tab" aria-selected="false">
            Guardar/MarcarSalida/Entrada
        </button>
        <button class="nav-link" id="nav-Cronograma" data-bs-toggle="tab" data-bs-target="#nav-Cronograma-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Cronograma
        </button>
        <button class="nav-link" id="nav-NotasAvance" data-bs-toggle="tab" data-bs-target="#nav-NotaAvance-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Notas de avance
        </button>
        <button class="nav-link" id="nav-PersonalProyecto" data-bs-toggle="tab"
            data-bs-target="#nav-PersonalProyecto-tab" type="button" role="tab" aria-controls="nav-contact"
            aria-selected="false">Personal del proyecto</button>
        <button class="nav-link" id="nav-Incidentes" data-bs-toggle="tab" data-bs-target="#nav-Incidentes-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Incidentes
        </button>
        <button class="nav-link" id="nav-Documentos" data-bs-toggle="tab" data-bs-target="#nav-Documentos-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Documentos
        </button>
        <button class="nav-link" id="nav-Materiales" data-bs-toggle="tab" data-bs-target="#nav-Materiales-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Materiales
        </button>
        <button class="nav-link" id="nav-ReporteFinanciero" data-bs-toggle="tab" data-bs-target="#nav-ReporteFinanciero-tab" type="button" role="tab" aria-controls="nav-home" aria-selected="true">
            Ver reporte financiero
        </button>
    </div>
</nav>

<div class="tab-content" id="nav-tabContent">

    <div class="tab-pane fade" id="nav-Marca-tab" role="tabpanel" aria-labelledby="nav-marcaEntradaSalida">
        Contenido del tab Guardar/Marcar Salida/Entrada.
    </div>

    <div class="tab-pane fade " id="nav-Cronograma-tab" role="tabpanel" aria-labelledby="nav-Cronograma">

        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#crearTareaModal">
            Nueva Tarea
        </button>

        <!-- Tabla de tareas del proyecto -->
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre de la Tarea</th>
                    <th>Fecha Esperada de Inicio</th>
                    <th>Fecha Esperada de Fin</th>
                    <th>Descripción</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <!-- Cuerpo de la tabla -->
            <tbody>
                @if (Model.Tareas != null && Model.Tareas.Any()) // Validamos que sí haya tareas
                {
                    @foreach (var tarea in Model.Tareas) // Recorremos la lista de tareas que creamos en
                    {
                        <tr>
                            <td>@tarea.Nombre</td>
                            <td>@tarea.FechaInicio.ToShortDateString()</td>
                            <td>@tarea.FechaFin.ToShortDateString()</td>
                            <td>@tarea.Descripcion</td>
                            <td>
                                    <div class="container">
                                        <div class="row">
                                            <div class="col">
                                                <!-- Content for column 1 --> 
                                                <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editarTareaModal"
                                                     data-id="@tarea.Id"
                                                     data-nombre="@tarea.Nombre"
                                                     data-descripcion="@tarea.Descripcion"
                                                     data-fechainicio="@tarea.FechaInicio.ToString(" yyyy-MM-dd")"
                                                     data-fechafin="@tarea.FechaFin.ToString(" yyyy-MM-dd")">
                                                <i class="fas fa-edit"></i> Editar
                                                </button>
                                            </div>
                                            <div class="col">
                                                <!-- Content for column 2 -->
                                                <form method="post" asp-page-handler="EliminarTarea" asp-route-IdTarea="@tarea.Id" asp-route-CodigoProyecto="@Model.CodigoProyecto" style="display:inline;">
                                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Desea eliminar esta tarea?')">
                                                    <i class="fas fa-trash"></i>  Eliminar
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                            </td>
                        </tr>
                    }
                }
                else // Si no hay tareas, mostramos un mensaje
                {
                <tr>
                    <td colspan="8" class="text-center">El proyecto no cuenta con tareas.</td>
                </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="tab-pane fade" id="nav-NotaAvance-tab" role="tabpanel" aria-labelledby="nav-NotasAvance">
         <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#crearNotaAvanceModal">
            Crear Nota
        </button>

        <!-- Tabla de notas de avance del proyecto -->
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Descripcion</th>
                    <th>Fecha Subida</th>
                    <th>Acciones</th> <!-- Columna para los botones de Editar, Eliminar -->
                </tr>
            </thead>

            <!-- Cuerpo de la tabla -->
            <tbody>
                @if (Model.Notas != null && Model.Notas.Any()) // Validamos que sí haya notas
                {
                    @foreach (var nota in Model.Notas.OrderByDescending(n => n.FechaNota))
                    {
                        // Definimos el tipo de fila según si queremos destacarla o no
                        var filaClase = nota.Destacada ? "table-success" : ""; // table-success para verde claro

                        <tr class="@filaClase">
                            <td>@nota.Descripcion</td>
                            <td>@nota.FechaNota.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="container">
                                    <div class="row">
                                        <div class="col">
                                            <!-- Content for column 1 -->
                                            <form method="post" asp-page-handler="DestacarNota" class="d-inline">
                                                <input type="hidden" name="idNota" value="@nota.IdNota" />
                                                <input type="hidden" name="CodigoProyecto" value="@Model.DetalleProyecto.CodigoProyecto" />
                                                <button type="submit" class="btn btn-success">
                                                    Destacar
                                                </button>
                                            </form>
                                        </div>
                                        <div class="col">
                                            <!-- Content for column 2 -->
                                            <button class="btn btn-warning"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editarNotaModal"
                                                    data-id="@nota.IdNota"
                                                    data-descripcion="@nota.Descripcion">
                                                <i class="fas fa-edit"></i>  Editar
                                            </button>
                                        </div>
                                        <div class="col">
                                            <!-- Content for column 3 -->
                                            <form method="post" asp-page-handler="EliminarNota" class="d-inline">
                                                <input type="hidden" name="idNota" value="@nota.IdNota" />
                                                <input type="hidden" name="CodigoProyecto" value="@Model.DetalleProyecto.CodigoProyecto" />
                                                <button type="submit" class="btn btn-danger" onclick="return confirm('¿Desea eliminar esta Nota?')">
                                                    <i class="fas fa-trash"></i> Eliminar
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else // Si no hay notas, mostrar fila con mensaje
                {
                    <tr>
                        <td colspan="4" class="text-center">El proyecto no cuenta con notas de avance.</td>
                    </tr>
                }

            </tbody>
        </table>
    </div>

    <div class="tab-pane fade" id="nav-PersonalProyecto-tab" role="tabpanel" aria-labelledby="nav-PersonalProyecto">
        <h4>Personal Asignado</h4>
        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#modalAgregarPersonal">
            Agregar Personal
        </button>

        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PersonalAsignado != null && Model.PersonalAsignado.Any()) // Validamos que sí haya tareas
                {
                    @foreach (var p in Model.PersonalAsignado)
                    {
                    <tr>
                        <td>@p.Nombre</td>
                        <td>
                                    <div class="container">
                                        <div class="row">
                                            <div class="col">
                                                <!-- Content for column 1 -->
                                                <form method="post" asp-page-handler="EliminarPersonal"
                                                      asp-route-CodigoProyecto="@Model.CodigoProyecto" asp-route-personalId="@p.PersonalId"
                                                      style="display:inline">
                                                <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Eliminar</button>
                                                </form>
                                            </div>
                                            <div class="col">
                                                <!-- Content for column 2 -->
                                                <button class="btn btn-warning btn-sm" data-bs-toggle="modal"
                                                        data-bs-target="#modalReasignarPersonal" data-antiguo="@p.PersonalId">
                                                <i class="fas fa-arrows-alt-h"></i> Reasignar
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                        </td>
                    </tr>
                    }
                }
                else
                {   <tr>
                        <td colspan="4" class="text-center">No hay personal asignado a este proyecto.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="tab-pane fade" id="nav-Incidentes-tab" role="tabpanel" aria-labelledby="nav-Incidentes">

        <!-- Botón para abrir modal -->
        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#crearIncidenteModal">
            Nuevo Incidente
        </button>

        <!-- Tabla de incidentes -->
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Descripción</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Incidentes != null && Model.Incidentes.Any())
                {
                    foreach (var incidente in Model.Incidentes)
                    {
                        <tr>
                            <td>@incidente.Descripcion</td>
                            <td>@incidente.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@incidente.Estado</td>
                            <td>
                                @if (incidente.Estado == "Abierto")
                                {
                                    <form method="post" asp-page-handler="CerrarIncidente"
                                          asp-route-idIncidente="@incidente.IdIncidente"
                                          asp-route-CodigoProyecto="@Model.CodigoProyecto"
                                          style="display:inline;">

                                        <button type="button" class="btn btn-sm btn-warning"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalEditarIncidente"
                                                data-id="@incidente.IdIncidente"
                                                data-descripcion="@incidente.Descripcion">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>

                                        <button type="button" class="btn btn-sm btn-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalCerrarIncidente"
                                                data-id="@incidente.IdIncidente"
                                                data-descripcion="@incidente.Descripcion">
                                            <i class="fa-solid fa-circle-xmark"></i> Cerrar
                                        </button>


                                    </form> 
                                }
                                else
                                {
                                    <span class="text-muted">Incidente cerrado</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">No hay incidentes registrados.</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

    <div class="tab-pane fade" id="nav-Documentos-tab" role="tabpanel" aria-labelledby="nav-Documentos">
        Contenido del tab Documentos.
    </div>

    <div class="tab-pane fade" id="nav-ReporteFinanciero-tab" role="tabpanel" aria-labelledby="nav-ReporteFinanciero">
        Contenido del tab Reporte financiero.
    </div>

    <div class="tab-pane fade" id="nav-Materiales-tab" role="tabpanel" aria-labelledby="nav-Materiales">
        <nav>
            <div class="nav nav-tabs" id="nav-tab" role="tablist">

                <button class="nav-link" id="nav-MaterialesProyecto" data-bs-toggle="tab"
                        data-bs-target="#nav-Materiales-tab" type="button" role="tab" aria-controls="nav-contact"
                        aria-selected="false">
                    Materiales en proyecto
                </button>
                <button class="nav-link" id="nav-SolicitudesMaterial" data-bs-toggle="tab"
                        data-bs-target="#nav-SolicitudMateriales-tab" type="button" role="tab" aria-controls="nav-contact"
                        aria-selected="false">
                    Solicitudes de material
                </button>

            </div>
        </nav>
        <div class="tab-content" id="nav-tabContent">
            <div class="tab-pane fade show active" id="nav-Materiales-tab" role="tabpanel" aria-labelledby="nav-MaterialesProyecto">
                Contenido del sub tab Materiales en proyecto.
                <table class="table table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre material</th>
                            <th>Cantidad</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.MaterialesProyecto != null && Model.MaterialesProyecto.Any())
                        {
                                foreach (var mat in Model.MaterialesProyecto)
                                {
                                    <tr>
                                        
                                        <td>@mat.NombreMaterial</td>
                                        <td>@mat.CantidadEnObra</td>
                                        <td>
                                            <div class="container">
                                                <div class="row">
                                                    <div class="col">
                                                        <!-- Contenido para columna accion 1 -->
                                                        <button class="btn btn-sm btn-warning"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#modalDisminuiMaterial"
                                                                data-idMaterialProyecto="@mat.IdMaterialProyecto"
                                                                data-nombreMaterial="@mat.NombreMaterial">
                                                        <i class="fa-solid fa-square-minus"></i> Disminuir
                                                        </button>
                                                    </div>
                                                    <div class="col">
                                                        <!-- Contenido para columna accion 2 -->
                                                    <button class="btn btn-sm btn-secondary"
                                                                data-bs-toggle="modal"
                                                            data-bs-target="#devolverMaterial"
                                                                data-id=""
                                                                data-email=""
                                                                data-nombre=""
                                                                data-rol="">
                                                        <i class="fa-solid fa-arrow-left"></i> Devolver
                                                        </button>
                                                    </div>
                                                <div class="col">
                                                    <!-- Contenido para columna accion 3 -->
                                                    <button class="btn btn-sm btn-danger">
                                                        <i class="fas fa-trash"></i> Eliminar
                                                    </button>
                                                </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center">No hay materiales registrados en este proyecto.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="tab-pane fade" id="nav-SolicitudMateriales-tab" role="tabpanel" aria-labelledby="nav-SolicitudesMaterial">

                <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#crearSolicitudModal">
                    Solicitar Material
                </button>


                <table class="table table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Material</th>
                            <th>Cantidad</th>
                            <th>Prioridad</th>
                            <th>Fecha Solicitud</th>
                            <th>Estado</th>
                            <th>Observaciones bodeguero</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.SolicitudesMaterial != null && Model.SolicitudesMaterial.Any())
                        {
                            foreach (var solicitud in Model.SolicitudesMaterial)
                            {
                                foreach (var mat in solicitud.MaterialesSolicitados)
                                {
                                    <tr>
                                        <td>@mat.NombreMaterial</td>
                                        <td>@mat.Cantidad</td>
                                        <td>@mat.Prioridad</td>
                                        <td>@solicitud.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@solicitud.EstadoSolicitud</td>
                                        <td>@solicitud.ObservacionesBodeguero</td>
                                        <td>
                                            @if (solicitud.EstadoSolicitud == "Abierta")
                                            {
                                                <button type="button" class="btn btn-sm btn-warning"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editarSolicitudModal"
                                                        data-id="@solicitud.IdSolicitud"
                                                        data-material="@mat.MaterialId"
                                                        data-cantidad="@mat.Cantidad"
                                                        data-prioridad="@mat.Prioridad">
                                                    Editar
                                                </button>

                                                <form method="post" asp-page-handler="EliminarSolicitud"
                                                      asp-route-idSolicitud="@solicitud.IdSolicitud"
                                                      asp-route-CodigoProyecto="@Model.CodigoProyecto"
                                                      style="display:inline;">
                                                    <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No editable</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center">No hay solicitudes registradas.</td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>

        </div>
    </div>
</div>

<!-- Modal: Crear Nueva Tarea -->
<div class="modal fade" id="crearTareaModal" tabindex="-1" aria-labelledby="crearTareaModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="CrearTarea">
                <div class="modal-header">
                    <h5 class="modal-title" id="crearTareaModalLabel">Nueva Tarea</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <!-- Nombre -->
                    <div class="mb-3">
                        <label for="Nombre" class="form-label">Nombre de la Tarea</label>
                        <input type="text" class="form-control" asp-for="NuevaTarea.Nombre" required />
                    </div>

                    <!-- Descripción -->
                    <div class="mb-3">
                        <label for="Descripcion" class="form-label">Descripción</label>
                        <textarea class="form-control" asp-for="NuevaTarea.Descripcion" rows="3" required></textarea>
                    </div>

                    <!-- Fecha Inicio -->
                    <div class="mb-3">
                        <label for="FechaInicio" class="form-label">Fecha Esperada de Inicio</label>
                        <input type="date" class="form-control" asp-for="NuevaTarea.FechaInicio" required
                            value="@DateTime.Today.ToString(" yyyy-MM-dd")" />
                    </div>

                    <!-- Fecha Fin -->
                    <div class="mb-3">
                        <label for="FechaFin" class="form-label">Fecha Esperada de Fin</label>
