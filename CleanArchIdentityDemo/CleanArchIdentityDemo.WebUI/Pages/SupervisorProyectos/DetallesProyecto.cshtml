@page
@model CleanArchIdentityDemo.WebUI.Pages.SupervisorProyectos.DetallesProyectoModel
@{
}
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 25px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" id="successToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" id="errorToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true" id="warningToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["WarningMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-info border-0" role="alert" aria-live="assertive" aria-atomic="true" id="infoToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-info-circle me-2"></i>
                    @TempData["InfoMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>
<!--Solamente a manera de prueba muestra el nombre y estado de proyecto  -->
@if (Model.DetalleProyecto != null)
{
    //<h1>@Model.DetalleProyecto.Nombre</h1>
    //<h1>@Model.DetalleProyecto.EstadoProyectoId</h1>
    <h2 class="text-2xl font-bold text-gray-800">Detalles del Proyecto - @Model.DetalleProyecto.Nombre</h2>
    <div class="row justify-content-between">
        <div class="col-4">
            <a asp-page="./ListaProyectos"><i class="fa-solid fa-arrow-left"></i> Volver a lista de proyectos </a>
        </div>
        <div class="col-4">
            <!--Boton para cambiar de estado el proyecto  -->
            <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#NuevoEstadoProyectoModal">
                Nuevo Estado
            </button>
        </div>
    </div>

}




<!--Muestra un mensaje de exito cuando se cambie el estado  -->
@if (TempData["MensajeExito"] != null)
{
<div class="alert alert-success alert-dismissible fade show" role="alert">
    @TempData["MensajeExito"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}


@if (TempData["ErrorPersonal"] != null)
{
<div class="modal fade" id="modalErrorPersonal" tabindex="-1" aria-modal="true" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Aviso</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p>@TempData["ErrorPersonal"]</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var myModal = new bootstrap.Modal(document.getElementById('modalErrorPersonal'));
        myModal.show();
    });
</script>
}



<nav>
    <div class="nav nav-tabs" id="nav-tab" role="tablist">
        <button class="nav-link" id="nav-marcaEntradaSalida" data-bs-toggle="tab" data-bs-target="#nav-Marca-tab" type="button" role="tab" aria-controls="nav-Marca-tab" aria-selected="false">
            Guardar/MarcarSalida/Entrada
        </button>
        <button class="nav-link" id="nav-Cronograma" data-bs-toggle="tab" data-bs-target="#nav-Cronograma-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Cronograma
        </button>
        <button class="nav-link" id="nav-NotasAvance" data-bs-toggle="tab" data-bs-target="#nav-NotaAvance-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Notas de avance
        </button>
        <button class="nav-link" id="nav-PersonalProyecto" data-bs-toggle="tab"
            data-bs-target="#nav-PersonalProyecto-tab" type="button" role="tab" aria-controls="nav-contact"
            aria-selected="false">Personal del proyecto</button>
        <button class="nav-link" id="nav-Incidentes" data-bs-toggle="tab" data-bs-target="#nav-Incidentes-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Incidentes
        </button>
        <button class="nav-link" id="nav-Documentos" data-bs-toggle="tab" data-bs-target="#nav-Documentos-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Documentos
        </button>
        <button class="nav-link" id="nav-Materiales" data-bs-toggle="tab" data-bs-target="#nav-Materiales-tab" type="button" role="tab" aria-controls="nav-contact" aria-selected="false">
            Materiales
        </button>
        <button class="nav-link" id="nav-ReporteFinanciero" data-bs-toggle="tab" data-bs-target="#nav-ReporteFinanciero-tab" type="button" role="tab" aria-controls="nav-home" aria-selected="true">
            Ver reporte financiero
        </button>
    </div>
</nav>

<div class="tab-content" id="nav-tabContent">

    <div class="tab-pane fade" id="nav-Marca-tab" role="tabpanel" aria-labelledby="nav-marcaEntradaSalida">
        <br />
        <div class="row justify-content-between">
            <div class="col-4">
               Lista de personal del proyecto
            </div>
            <div class="col-4">
                <button class="btn btn-secondary mb-3" data-bs-toggle="modal" data-bs-target="#">
                    Ver reporte
                </button>
            </div>
        </div>
        <!-- Tabla donde se muuestra el personal actualmente en el proyecto -->

    </div>

    <div class="tab-pane fade " id="nav-Cronograma-tab" role="tabpanel" aria-labelledby="nav-Cronograma">
        <br />
        <div class="row justify-content-between">
            <div class="col-4">
                Tareas del proyecto
            </div>
            <div class="col-4">
                <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#crearTareaModal">
                    Nueva Tarea
                </button>
            </div>
        </div>
        

        <!-- Tabla de tareas del proyecto -->
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre de la Tarea</th>
                    <th>Fecha Esperada de Inicio</th>
                    <th>Fecha Esperada de Fin</th>
                    <th>Descripción</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <!-- Cuerpo de la tabla -->
            <tbody>
                @if (Model.Tareas != null && Model.Tareas.Any()) // Validamos que sí haya tareas
                {
                    @foreach (var tarea in Model.Tareas) // Recorremos la lista de tareas que creamos en
                    {
                        <tr>
                            <td>@tarea.Nombre</td>
                            <td>@tarea.FechaInicio.ToShortDateString()</td>
                            <td>@tarea.FechaFin.ToShortDateString()</td>
                            <td>@tarea.Descripcion</td>
                            <td>
                                    <div class="container">
                                        <div class="row">
                                            <div class="col">
                                                <!-- Content for column 1 --> 
                                                <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editarTareaModal"
                                                     data-id="@tarea.Id"
                                                     data-nombre="@tarea.Nombre"
                                                     data-descripcion="@tarea.Descripcion"
                                                     data-fechainicio="@tarea.FechaInicio.ToString(" yyyy-MM-dd")"
                                                     data-fechafin="@tarea.FechaFin.ToString(" yyyy-MM-dd")">
                                                <i class="fas fa-edit"></i> Editar
                                                </button>
                                            </div>
                                            <div class="col">
                                                <!-- Content for column 2 -->
                                                <form method="post" asp-page-handler="EliminarTarea" asp-route-IdTarea="@tarea.Id" asp-route-CodigoProyecto="@Model.CodigoProyecto" style="display:inline;">
                                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Desea eliminar esta tarea?')">
                                                    <i class="fas fa-trash"></i>  Eliminar
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                            </td>
                        </tr>
                    }
                }
                else // Si no hay tareas, mostramos un mensaje
                {
                <tr>
                    <td colspan="8" class="text-center">El proyecto no cuenta con tareas.</td>
                </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="tab-pane fade" id="nav-NotaAvance-tab" role="tabpanel" aria-labelledby="nav-NotasAvance">
        <br />
        <div class="row justify-content-between">
            <div class="col-4">
                Notas de avance del proyecto
            </div>
            <div class="col-4">
                <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#crearNotaAvanceModal">
                    Crear Nota
                </button>
            </div>
        </div>
        

        <!-- Tabla de notas de avance del proyecto -->
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Descripcion</th>
                    <th>Fecha Subida</th>
                    <th>Acciones</th> <!-- Columna para los botones de Editar, Eliminar -->
                </tr>
            </thead>

            <!-- Cuerpo de la tabla -->
            <tbody>
                @if (Model.Notas != null && Model.Notas.Any()) // Validamos que sí haya notas
                {
                    @foreach (var nota in Model.Notas.OrderByDescending(n => n.FechaNota))
                    {
                        // Definimos el tipo de fila según si queremos destacarla o no
                        var filaClase = nota.Destacada ? "table-success" : ""; // table-success para verde claro

                        <tr class="@filaClase">
                            <td>@nota.Descripcion</td>
                            <td>@nota.FechaNota.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="container">
                                    <div class="row">
                                        <div class="col">
                                            <!-- Content for column 1 -->
                                            <form method="post" asp-page-handler="DestacarNota" class="d-inline">
                                                <input type="hidden" name="idNota" value="@nota.IdNota" />
                                                <input type="hidden" name="CodigoProyecto" value="@Model.DetalleProyecto.CodigoProyecto" />
                                                <button type="submit" class="btn btn-success">
                                                    Destacar
                                                </button>
                                            </form>
                                        </div>
                                        <div class="col">
                                            <!-- Content for column 2 -->
                                            <button class="btn btn-warning"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editarNotaModal"
                                                    data-id="@nota.IdNota"
                                                    data-descripcion="@nota.Descripcion">
                                                <i class="fas fa-edit"></i>  Editar
                                            </button>
                                        </div>
                                        <div class="col">
                                            <!-- Content for column 3 -->
                                            <form method="post" asp-page-handler="EliminarNota" class="d-inline">
                                                <input type="hidden" name="idNota" value="@nota.IdNota" />
                                                <input type="hidden" name="CodigoProyecto" value="@Model.DetalleProyecto.CodigoProyecto" />
                                                <button type="submit" class="btn btn-danger" onclick="return confirm('¿Desea eliminar esta Nota?')">
                                                    <i class="fas fa-trash"></i> Eliminar
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else // Si no hay notas, mostrar fila con mensaje
                {
                    <tr>
                        <td colspan="4" class="text-center">El proyecto no cuenta con notas de avance.</td>
                    </tr>
                }

            </tbody>
        </table>
    </div>

    <div class="tab-pane fade" id="nav-PersonalProyecto-tab" role="tabpanel" aria-labelledby="nav-PersonalProyecto">
        <br />
        <div class="row justify-content-between">
            <div class="col-4">
                Personal Asignado
            </div>
            <div class="col-4">
                <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#modalAgregarPersonal">
                    Agregar Personal
                </button>
            </div>
        </div>
       
       

        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PersonalAsignado != null && Model.PersonalAsignado.Any()) // Validamos que sí haya tareas
                {
                    @foreach (var p in Model.PersonalAsignado)
                    {
                    <tr>
                        <td>@p.Nombre</td>
                        <td>
                                    <div class="container">
                                        <div class="row">
                                            <div class="col">
                                                <!-- Content for column 1 -->
                                                <form method="post" asp-page-handler="EliminarPersonal"
                                                      asp-route-CodigoProyecto="@Model.CodigoProyecto" asp-route-personalId="@p.PersonalId"
                                                      style="display:inline">
                                                <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Eliminar</button>
                                                </form>
                                            </div>
                                            <div class="col">
                                                <!-- Content for column 2 -->
                                                <button class="btn btn-warning btn-sm" data-bs-toggle="modal"
                                                        data-bs-target="#modalReasignarPersonal" data-antiguo="@p.PersonalId">
                                                <i class="fas fa-arrows-alt-h"></i> Reasignar
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                        </td>
                    </tr>
                    }
                }
                else
                {   <tr>
                        <td colspan="4" class="text-center">No hay personal asignado a este proyecto.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="tab-pane fade" id="nav-Incidentes-tab" role="tabpanel" aria-labelledby="nav-Incidentes">
        <br />
        <div class="row justify-content-between">
            <div class="col-4">
                Incidentes del proyecto
            </div>
            <div class="col-4">
                <!-- Botón para abrir modal -->
                <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#crearIncidenteModal">
                    Nuevo Incidente
                </button>
            </div>
        </div>
       

        <!-- Tabla de incidentes -->
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Descripción</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Incidentes != null && Model.Incidentes.Any())
                {
                    foreach (var incidente in Model.Incidentes)
                    {
                        <tr>
                            <td>@incidente.Descripcion</td>
                            <td>@incidente.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@incidente.Estado</td>
                            <td>
                                @if (incidente.Estado == "Abierto")
                                {
                                    <form method="post" asp-page-handler="CerrarIncidente"
                                          asp-route-idIncidente="@incidente.IdIncidente"
                                          asp-route-CodigoProyecto="@Model.CodigoProyecto"
                                          style="display:inline;">

                                        <button type="button" class="btn btn-sm btn-warning"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalEditarIncidente"
                                                data-id="@incidente.IdIncidente"
                                                data-descripcion="@incidente.Descripcion">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>

                                        <button type="button" class="btn btn-sm btn-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalCerrarIncidente"
                                                data-id="@incidente.IdIncidente"
                                                data-descripcion="@incidente.Descripcion">
                                            <i class="fa-solid fa-circle-xmark"></i> Cerrar
                                        </button>


                                    </form> 
                                }
                                else
                                {
                                    <span class="text-muted">Incidente cerrado</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">No hay incidentes registrados.</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

    <div class="tab-pane fade" id="nav-Documentos-tab" role="tabpanel" aria-labelledby="nav-Documentos">
        <br />
        <div class="container-fluid mt-4">
            <!-- Header con botones de acción -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h4 class="mb-0">
                                <i class="fas fa-folder-open text-primary"></i>
                                Documentos del Proyecto
                            </h4>
                            <small class="text-muted">
                                @Model.Documentos.Count documento(s) |
                                @Model.Documentos.Count(d => d.TipoDocumento == "Versionado") versionado(s) |
                                @Model.Documentos.Count(d => d.TipoDocumento == "Simple") simple(s)
                            </small>
                        </div>
                        <div class="col-md-6 text-end">
                            <div class="btn-group" role="group" aria-label="Acciones de documentos">
                                <button type="button"
                                        class="btn btn-primary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalDocumentoVersionado"
                                        title="Crear documento con control de versiones">
                                    <i class="fas fa-layer-group"></i> Documento Versionado
                                </button>
                                <button type="button"
                                        class="btn btn-info"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalNuevaVersion"
                                        title="Agregar versión a documento existente">
                                    <i class="fas fa-code-branch"></i> Nueva Versión
                                </button>
                                <button type="button"
                                        class="btn btn-success"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalDocumentoSimple"
                                        title="Subir documento único sin versiones">
                                    <i class="fas fa-file"></i> Documento Simple
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        <!-- Listado de Documentos -->
        @if (!Model.Documentos.Any())
        {
            <div class="alert alert-info d-flex align-items-center" role="alert">
                <i class="fas fa-info-circle fa-2x me-3"></i>
                <div>
                    <h5 class="alert-heading mb-1">No hay documentos</h5>
                    <p class="mb-0">
                        Comience agregando un documento versionado o uno simple al proyecton, acá verá el historial de documentos simples o con versiones.
                    </p>
                </div>
            </div>
        }
        else
        {
            @foreach (var doc in Model.Documentos.OrderByDescending(d => d.FechaSubida))
            {
                <div class="card mb-3 shadow-sm border-0">
                    <!-- Card Header con información del documento -->
                    <div class="card-header @(doc.TipoDocumento == "Versionado" ? "bg-primary text-white" : "bg-success text-white")">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h5 class="mb-1">
                                    @if (doc.TipoDocumento == "Versionado")
                                    {
                                        <i class="fas fa-layer-group"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-file"></i>
                                    }
                                    @doc.NombreDocumento
                                
                                    @if (doc.TipoDocumento == "Versionado")
                                    {
                                        <span class="badge bg-light text-dark">@doc.VersionActual</span>
                                    }
                                
                                    @if (!string.IsNullOrEmpty(doc.CategoriaDocumento))
                                    {
                                        <span class="badge bg-secondary">@doc.CategoriaDocumento</span>
                                    }
                                </h5>
                                @* @if (!string.IsNullOrEmpty(doc.Descripcion))
                                {
                                    <small class="d-block mt-1">
                                        @doc.Descripcion
                                    </small>
                                } *@
                            </div>
                            <div class="col-md-4 text-end">
                                @if (doc.TipoDocumento == "Versionado")
                                {
                                    <span class="badge bg-light text-dark me-2 fs-6">
                                         @doc.TotalVersiones versión(es)
                                    </span>
                                    <button type="button"
                                            class="btn btn-sm btn-light" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#modalNuevaVersion"
                                            onclick="preseleccionarDocumento(@doc.IdDocumento)"
                                            title="Agregar nueva versión a este documento">
                                        <i class="fas fa-plus"></i> Nueva Versión
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark fs-6">
                                        <i class="fas fa-file"></i> Documento único
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                
                    <!-- Card Body con tabla de versiones o info del documento simple -->
                    <div class="card-body p-0">
                        @if (doc.TipoDocumento == "Versionado")
                        {
                            <!-- TABLA DE VERSIONES -->
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 8%;" class="text-center">Versión</th>
                                            <th style="width: 25%;">Archivo</th>
                                            <th style="width: 10%;" class="text-center">Tamaño</th>
                                            <th style="width: 15%;">Subido por</th>
                                            <th style="width: 12%;" class="text-center">Fecha</th>
                                            <th style="width: 20%;">Comentarios</th>
                                            <th style="width: 10%;" class="text-center">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var version in doc.Versiones.OrderByDescending(v => v.NumeroVersion))
                                        {
                                            <tr class="@(version.EsVersionActual ? "table-success" : "")">
                                                <!-- Versión -->
                                                <td class="text-center align-middle">
                                                    <strong class="d-block">@version.NumeroVersion</strong>
                                                    @if (version.EsVersionActual)
                                                    {
                                                        <span class="badge bg-success mt-1">
                                                            <i class="fas fa-check"></i> Actual
                                                        </span>
                                                    }
                                                </td>
                                            
                                                <!-- Archivo -->
                                                <td class="align-middle">
                                                    <i class="fas @version.IconoArchivo fa-lg me-2"></i>
                                                    <span>@version.NombreArchivoOriginal</span>
                                                </td>
                                            
                                                <!-- Tamaño -->
                                                <td class="text-center align-middle">
                                                    <span class="badge bg-light text-dark">
                                                        @version.TamanoFormateado
                                                    </span>
                                                </td>
                                            
                                                <!-- Subido por -->
                                                <td class="align-middle">
                                                    <small>
                                                        
                                                        @version.NombreSubidoPor
                                                    </small>
                                                </td>
                                            
                                                <!-- Fecha -->
                                                <td class="text-center align-middle">
                                                    <small class="d-block">
                                                        
                                                        @version.FechaSubida.ToString("dd/MM/yyyy")
                                                    </small>
                                                    <small class="text-muted">
                                                        <i class="fas fa-clock"></i>
                                                        @version.FechaSubida.ToString("HH:mm")
                                                    </small>
                                                </td>
                                            
                                                <!-- Comentarios -->
                                                <td class="align-middle">
                                                    <small class="text-muted">
                                                        @if (!string.IsNullOrEmpty(version.Comentarios))
                                                        {
                                                           
                                                            @version.Comentarios
                                                        }
                                                        else
                                                        {
                                                                <p>Sin comentarios</p>
                                                        }
                                                    </small>
                                                </td>
                                            
                                                <!-- Acciones -->
                                                <td class="text-center align-middle">
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <!-- Descargar -->
                                                        <a asp-page-handler="DescargarVersion" 
                                                           asp-route-idVersion="@version.IdVersion"
                                                           class="btn btn-outline-primary" 
                                                           title="Descargar versión @version.NumeroVersion">
                                                            <i class="fas fa-download"></i>
                                                        </a>
                                                    
                                                        <!-- Ver version en nueva pestaña -->
                                                            <a asp-page-handler="VerVersion"
                                                               asp-route-idVersion="@version.IdVersion"
                                                               target="_blank"
                                                               class="btn btn-outline-secondary"
                                                               title="Ver versión @version.NumeroVersion">
                                                                <i class="fas fa-eye"></i>
                                                            </a>
                                                    
                                                        <!-- Marcar como actual (solo si NO es la actual) -->
                                                        @if (!version.EsVersionActual)
                                                        {
                                                            <form method="post" 
                                                                  asp-page-handler="MarcarComoActual" 
                                                                  style="display:inline;"
                                                                  onsubmit="return confirm('¿Marcar @version.NumeroVersion como versión actual?\n\nEsto cambiará la versión de referencia del documento.');">
                                                                <input type="hidden" name="idVersion" value="@version.IdVersion" />
                                                                <input type="hidden" asp-for="CodigoProyecto" />
                                                                <button type="submit" 
                                                                        class="btn btn-outline-success" 
                                                                        title="Marcar como versión actual">
                                                                    <i class="fas fa-check"></i>
                                                                        </button>
                                                                    </form>

                                                                    <!-- Eliminar versión (solo si NO es la actual) -->
                                                                    <form method="post"
                                                                          asp-page-handler="EliminarVersion"
                                                                          style="display:inline;"
                                                                          onsubmit="return confirm('⚠️ ¿Eliminar la versión @version.NumeroVersion?\n\nEsta acción no se puede deshacer.\n\nEl archivo se eliminará del sistema.');">
                                                                        <input type="hidden" name="idVersion" value="@version.IdVersion" />
                                                                        <input type="hidden" asp-for="CodigoProyecto" />
                                                                        <button type="submit"
                                                                                class="btn btn-outline-danger"
                                                                                title="Eliminar esta versión">
                                                                            <i class="fas fa-trash"></i>
                                                                        </button>
                                                                    </form>
                                                                }
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                        }
                         else
                        {
                                    <!--  para documento simple (que no tiene versiones) -->
                                    <div class="p-4">
                                        <div class="row align-items-center">
                                            <div class="col-md-8">
                                                <div class="d-flex align-items-center">
                                                    <!-- Icono grande del tipo de archivo -->
                                                    <div class="me-3">
                                                        <i class="fas @doc.IconoArchivo fa-4x"></i>
                                                    </div>

                                                    <!-- Información del archivo -->
                                                    <div>
                                                        <h6 class="mb-2">
                                                            <strong>@doc.NombreArchivoOriginal</strong>
                                                        </h6>

                                                        <div class="mb-1">
                                                            <span class="badge bg-light text-dark me-2">
                                                                <i class="fas fa-hdd"></i>
                                                                Tamaño: @doc.TamanoFormateado
                                                            </span>
                                                            <span class="badge bg-light text-dark">
                                                                <i class="fas fa-file-code"></i>
                                                                @doc.TipoArchivo
                                                            </span>
                                                        </div>

                                                        <small class="text-muted d-block">

                                                        <strong>Subido por </strong>@doc.NombreCreadoPor
                                                        </small>
                                                        <small class="text-muted">
                                                            <i class="fas fa-calendar-alt"></i>
                                                            @doc.FechaSubida.ToString("dd/MM/yyyy HH:mm")
                                                        </small>

                                                        @if (!string.IsNullOrEmpty(doc.Descripcion))
                                                        {
                                                            <div class="mt-2">
                                                                <small class="text-muted">
                                                                <strong>
                                                                    Descripción:
                                                                </strong>
                                                                    @doc.Descripcion
                                                                </small>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                        <div class="mt-2">
                                                            <small class="text-muted">
                                                                <strong>
                                                                    Descripción:
                                                                </strong>
                                                                Sin descripción
                                                            </small>
                                                        </div>
                                                        }
                                                </div>
                                                </div>
                                            </div>

                                            <!-- Acciones para documento simple -->
                                            <div class="col-md-4 text-end">
                                                <div class="btn-group-vertical" role="group">
                                                    <!-- Descargar -->
                                                    <a asp-page-handler="DescargarDocumento"
                                                       asp-route-idDocumento="@doc.IdDocumento"
                                                       class="btn btn-primary mb-2">
                                                        <i class="fas fa-download"></i> Descargar
                                                    </a>

                                                    <!-- Ver en nueva pestaña -->
                                                    <a asp-page-handler="VerDocumento"
                                                       asp-route-idDocumento="@doc.IdDocumento"
                                                       target="_blank"
                                                       class="btn btn-secondary mb-2">
                                                        <i class="fas fa-eye"></i> Ver en Navegador
                                                    </a>

                                                    <!-- Eliminar documento -->
                                                    <form method="post"
                                                          asp-page-handler="EliminarDocumento"
                                                          class="d-inline"
                                                          onsubmit="return confirm('⚠️ ¿Eliminar el documento &quot;@doc.NombreDocumento&quot;?\n\nEsta acción no se puede deshacer.\n\nEl archivo se eliminará del sistema permanentemente.');">
                                                        <input type="hidden" name="idDocumento" value="@doc.IdDocumento" />
                                                        <input type="hidden" asp-for="CodigoProyecto" />
                                                        <button type="submit" class="btn btn-danger w-100">
                                                            <i class="fas fa-trash"></i> Eliminar Documento
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                        }
                    </div>

                            <!-- CARD FOOTER - Información de Auditoría -->
                            <div class="card-footer text-muted bg-light">
                                <div class="row">
                                    <div class="col-md-6">
                                        <small>
                                            <strong>Creado por:</strong> @doc.NombreCreadoPor
                                        </small>
                                        <br />
                                        <small>
                                            <strong>Fecha de creación:</strong> @doc.FechaSubida.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    </div>
                                    <div class="col-md-6 text-end">
                                        @if (doc.FechaSubida != doc.UltimaModificacion)
                                        {
                                            <small>
                                                <strong>Última modificación:</strong>
                                                @doc.UltimaModificacion.ToString("dd/MM/yyyy HH:mm")
                                            </small>
                                            <br />
                                            @if (doc.TipoDocumento == "Versionado")
                                            {
                                                var ultimaVersion = doc.Versiones.OrderByDescending(v => v.NumeroVersion).FirstOrDefault();
                                                if (ultimaVersion != null)
                                                {
                                                    <small class="text-muted">
                                                        Última versión subida por <strong>@ultimaVersion.NombreSubidoPor</strong>
                                                    </small>
                                                }
                                            }
                                        }
                                        else
                                        {
                                            <small class="text-muted">
                                                <i class="fas fa-info-circle"></i>
                                                Sin modificaciones
                                            </small>
                                        }
                                    </div>
                                </div>

                                <!-- Botón de eliminar documento completo (para versionados) -->
                                @if (doc.TipoDocumento == "Versionado")
                                {
                                    <div class="mt-2 pt-2 border-top">
                                        <form method="post"
                                              asp-page-handler="EliminarDocumento"
                                              class="d-inline float-end"
                                              onsubmit="return confirm('⚠️ ¿Eliminar COMPLETAMENTE el documento &quot;@doc.NombreDocumento&quot; y TODAS sus versiones (@doc.TotalVersiones)?\n\nEsta acción no se puede deshacer.\n\nTodos los archivos asociados se eliminarán del sistema.');">
                                            <input type="hidden" name="idDocumento" value="@doc.IdDocumento" />
                                            <input type="hidden" asp-for="CodigoProyecto" />
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash-alt"></i> Eliminar documento completo
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                      </div>
                    }
                }
            </div>
        </div>

    <div class="tab-pane fade" id="nav-ReporteFinanciero-tab" role="tabpanel" aria-labelledby="nav-ReporteFinanciero">
        <br />
        Contenido del tab Reporte financiero.
    </div>

    <div class="tab-pane fade" id="nav-Materiales-tab" role="tabpanel" aria-labelledby="nav-Materiales">
        <nav>
            <div class="nav nav-tabs" id="nav-tab" role="tablist">

                <button class="nav-link" id="nav-MaterialesProyecto" data-bs-toggle="tab"
                        data-bs-target="#nav-Materiales-tab" type="button" role="tab" aria-controls="nav-contact"
                        aria-selected="false">
                    Materiales en proyecto
                </button>
                <button class="nav-link" id="nav-SolicitudesMaterial" data-bs-toggle="tab"
                        data-bs-target="#nav-SolicitudMateriales-tab" type="button" role="tab" aria-controls="nav-contact"
                        aria-selected="false">
                    Solicitudes de material
                </button>

            </div>
        </nav>
        <div class="tab-content" id="nav-tabContent">
            <div class="tab-pane fade show active" id="nav-Materiales-tab" role="tabpanel" aria-labelledby="nav-MaterialesProyecto">
                <br />
                Contenido del sub tab Materiales en proyecto.
                <table class="table table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre material</th>
                            <th>Cantidad</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.MaterialesProyecto != null && Model.MaterialesProyecto.Any())
                        {
                                foreach (var mat in Model.MaterialesProyecto)
                                {
                                    <tr>
                                        
                                        <td>@mat.NombreMaterial</td>
                                        <td>@mat.CantidadEnObra</td>
                                        <td>
                                            <div class="container">
                                                <div class="row">
                                                    <div class="col">
                                                        <!-- Contenido para columna accion 1 -->
                                                        <button class="btn btn-sm btn-warning"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#modalDisminuiMaterial"
                                                                data-idMaterialProyecto="@mat.IdMaterialProyecto"
                                                                data-nombreMaterial="@mat.NombreMaterial">
                                                        <i class="fa-solid fa-square-minus"></i> Disminuir material
                                                        </button>
                                                    </div>
                                                    <div class="col">
                                                        <!-- Contenido para columna accion 2 -->
                                                    <button class="btn btn-sm btn-secondary"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#modalDevolverMaterial"
                                                                data-idMaterialDevolver="@mat.MaterialId"
                                                                data-nombreMaterialDevolver="@mat.NombreMaterial"
                                                                data-idMaterialProyectoDevolver="@mat.IdMaterialProyecto">
                                                        <i class="fa-solid fa-arrow-left"></i> Devolver material
                                                        </button>
                                                    </div>
                                                <div class="col">
                                                    <!-- Contenido para columna accion 3 -->
                                                    <button class="btn btn-sm btn-danger"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#modalEliminarMaterialProyecto"
                                                            data-idMaterialEliminacionDevolver="@mat.MaterialId"
                                                            data-nombreMaterialEliminar="@mat.NombreMaterial"
                                                            data-idMaterialProyectoEliminar="@mat.IdMaterialProyecto"
                                                            data-cantidadEliminarMaterial="@mat.CantidadEnObra">
                                                        <i class="fas fa-trash"></i> Eliminar
                                                    </button>
                                                </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center">No hay materiales registrados en este proyecto.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="tab-pane fade" id="nav-SolicitudMateriales-tab" role="tabpanel" aria-labelledby="nav-SolicitudesMaterial">
                <br />
                <div class="row justify-content-between">
                    <div class="col-4">
                        Solicitudes de material para el proyecto
                    </div>
                    <div class="col-4">
                        <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#crearSolicitudModal">
                            Solicitar Material
                        </button>
                    </div>
                </div>
                


                <table class="table table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Material</th>
                            <th>Cantidad</th>
                            <th>Prioridad</th>
                            <th>Fecha Solicitud</th>
                            <th>Estado</th>
                            <th>Observaciones bodeguero</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.SolicitudesMaterial != null && Model.SolicitudesMaterial.Any())
                        {
                            foreach (var solicitud in Model.SolicitudesMaterial)
                            {
                                foreach (var mat in solicitud.MaterialesSolicitados)
                                {
                                    <tr>
                                        <td>@mat.NombreMaterial</td>
                                        <td>@mat.Cantidad</td>
                                        <td>@mat.Prioridad</td>
                                        <td>@solicitud.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@solicitud.EstadoSolicitud</td>
                                        <td>@solicitud.ObservacionesBodeguero</td>
                                        <td>
                                            @if (solicitud.EstadoSolicitud == "Abierta")
                                            {
                                                <button type="button" class="btn btn-sm btn-warning"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editarSolicitudModal"
                                                        data-id="@solicitud.IdSolicitud"
                                                        data-material="@mat.MaterialId"
                                                        data-cantidad="@mat.Cantidad"
                                                        data-prioridad="@mat.Prioridad">
                                                    <i class="fas fa-edit"></i> Editar
                                                </button>

                                                <form method="post" asp-page-handler="EliminarSolicitud"
                                                      asp-route-idSolicitud="@solicitud.IdSolicitud"
                                                      asp-route-CodigoProyecto="@Model.CodigoProyecto"
                                                      style="display:inline;">
                                                    <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Eliminar</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No editable</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center">No hay solicitudes registradas.</td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>

        </div>
    </div>
</div>

<!-- Modal: Crear Nueva Tarea -->
<div class="modal fade" id="crearTareaModal" tabindex="-1" aria-labelledby="crearTareaModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="CrearTarea">
                <div class="modal-header">
                    <h5 class="modal-title" id="crearTareaModalLabel">Nueva Tarea</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <!-- Nombre -->
                    <div class="mb-3">
                        <label for="Nombre" class="form-label">Nombre de la Tarea</label>
                        <input type="text" class="form-control" asp-for="NuevaTarea.Nombre" required />
                    </div>

                    <!-- Descripción -->
                    <div class="mb-3">
                        <label for="Descripcion" class="form-label">Descripción</label>
                        <textarea class="form-control" asp-for="NuevaTarea.Descripcion" rows="3" required></textarea>
                    </div>

                    <!-- Fecha Inicio -->
                    <div class="mb-3">
                        <label for="FechaInicio" class="form-label">Fecha Esperada de Inicio</label>
                        <input type="date" class="form-control" asp-for="NuevaTarea.FechaInicio" required
                            value="@DateTime.Today.ToString(" yyyy-MM-dd")" />
                    </div>

                    <!-- Fecha Fin -->
                    <div class="mb-3">
                        <label for="FechaFin" class="form-label">Fecha Esperada de Fin</label>
                        <input type="date" class="form-control" asp-for="NuevaTarea.FechaFin" required
                            value="@DateTime.Today.ToString(" yyyy-MM-dd")" />
                    </div>

                    <!-- Id del proyecto oculto -->
                    <input type="hidden" asp-for="NuevaTarea.ProyectoId" value="@Model.DetalleProyecto.IdProyecto" />
                    <input type="hidden" asp-for="CodigoProyecto" value="@Model.DetalleProyecto.CodigoProyecto" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Agregar Tarea</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Editar Tarea -->
<div class="modal fade" id="editarTareaModal" tabindex="-1" aria-labelledby="editarTareaLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="EditarTarea">
                <div class="modal-header">
                    <h5 class="modal-title" id="editarTareaLabel">Editar Tarea</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">

                    <!-- Hidden para Id de la tarea -->
                    <input type="hidden" asp-for="NuevaTarea.Id" id="edit-id" />
                    <input type="hidden" asp-for="CodigoProyecto" value="@Model.DetalleProyecto.CodigoProyecto" />

                    <!-- Nombre -->
                    <div class="mb-3">
                        <label for="edit-nombre" class="form-label">Nombre</label>
                        <input type="text" class="form-control" asp-for="NuevaTarea.Nombre" id="edit-nombre" required />
                    </div>

                    <!-- Descripción -->
                    <div class="mb-3">
                        <label for="edit-descripcion" class="form-label">Descripción</label>
                        <textarea class="form-control" asp-for="NuevaTarea.Descripcion" id="edit-descripcion"
                            required></textarea>
                    </div>

                    <!-- Fecha Inicio -->
                    <div class="mb-3">
                        <label for="edit-fechainicio" class="form-label">Fecha Inicio</label>
                        <input type="date" class="form-control" asp-for="NuevaTarea.FechaInicio" id="edit-fechainicio"
                            required value="@DateTime.Today.ToString(" yyyy-MM-dd")" />
                    </div>

                    <!-- Fecha Fin -->
                    <div class="mb-3">
                        <label for="edit-fechafin" class="form-label">Fecha Fin</label>
                        <input type="date" class="form-control" asp-for="NuevaTarea.FechaFin" id="edit-fechafin"
                            required value="@DateTime.Today.ToString(" yyyy-MM-dd")" />
                    </div>

                    <!-- Hidden ProyectoId -->
                    <input type="hidden" asp-for="NuevaTarea.ProyectoId" value="@Model.DetalleProyecto.IdProyecto" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Nuevo Estado Proyecto -->
<div class="modal fade" id="NuevoEstadoProyectoModal" tabindex="-1" aria-labelledby="NuevoEstadoProyectoModalLabel"
    aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="CambiarEstado">
                <div class="modal-header">
                    <h5 class="modal-title" id="NuevoEstadoProyectoModalLabel">Cambiar Estado del Proyecto</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="CodigoProyecto" value="@Model.DetalleProyecto.CodigoProyecto" />
                    <div class="mb-3">
                        <label for="EstadoProyecto" class="form-label">Selecciona el nuevo estado</label>
                        <select class="form-select" asp-for="NuevoEstado" required>
                            <option value="1">Planificado</option>
                            <option value="2">En ejecucion</option>
                            <option value="3">Finalizado</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Cambiar Estado</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Agregar Personal -->
<div class="modal fade" id="modalAgregarPersonal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="AsignarPersonal">
                <div class="modal-header">
                    <h5 class="modal-title">Asignar nuevo personal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="CodigoProyecto" />
                    <div class="mb-3">
                        <label class="form-label">Selecciona un usuario</label>
                        <select asp-for="UsuarioSeleccionado" class="form-select">
                            @foreach (var u in Model.UsuariosDisponibles)
                            {
                            <option value="@u.Id">@u.NombreCompleto</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Asignar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Reasignar Personal -->
<div class="modal fade" id="modalReasignarPersonal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="ReasignarPersonal">
                <div class="modal-header">
                    <h5 class="modal-title">Reasignar Personal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
