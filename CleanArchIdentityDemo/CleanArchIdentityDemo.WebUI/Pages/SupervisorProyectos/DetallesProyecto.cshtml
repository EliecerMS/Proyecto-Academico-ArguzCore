<!-- Modal: Crear documento con versiones-->
<div class="modal fade" id="modalDocumentoVersionado" tabindex="-1" aria-labelledby="modalVersionadoLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" enctype="multipart/form-data" asp-page-handler="CrearDocumentoVersionado" id="formDocumentoVersionado">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalVersionadoLabel">
                        <i class="fas fa-layer-group"></i> Nuevo Documento Versionado
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="CodigoProyecto" />

                    <!-- Alert Informativo -->
                    <div class="alert alert-info mb-3">
                        <i class="fas fa-info-circle"></i>
                        <strong>Documento Versionado:</strong> Permite mantener un historial de versiones del mismo documento.
                        Ideal para planos, contratos, especificaciones que se revisan constantemente.
                    </div>

                    <!-- Nombre del Documento -->
                    <div class="mb-3">
                        <label class="form-label">
                            Nombre del Documento
                            <span class="text-danger">*</span>
                        </label>
                        <input type="text"
                               class="form-control"
                               asp-for="NombreDocumentoVersionado"
                               placeholder="Ej: Plano Estructural Principal"
                               required
                               maxlength="255" />
                        <small class="text-muted">
                            Este será el nombre general del documento (todas las versiones tendrán este nombre)
                        </small>
                    </div>

                    <!-- Categoría -->
                    <div class="mb-3">
                        <label class="form-label">
                           Categoría
                        </label>
                        <select class="form-select" asp-for="CategoriaDocumentoVersionado">
                            <option value="">Seleccione una categoría...</option>
                            <option value="Plano">Plano</option>
                            <option value="Contrato">Contrato</option>
                            <option value="Especificación">Especificación</option>
                            <option value="Informe">Informe</option>
                            <option value="Memoria de Cálculo">Memoria de Cálculo</option>
                            <option value="Presupuesto">Presupuesto</option>
                            <option value="Estudio">Estudio</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>

                    <!-- Descripción -->
                    <div class="mb-3">
                        <label class="form-label">
                            Descripción
                        </label>
                        <textarea class="form-control"
                                  asp-for="DescripcionDocumentoVersionado"
                                  rows="2"
                                  maxlength="500"
                                  placeholder="Descripción general del documento (opcional)"></textarea>
                        <small class="text-muted">Máximo 500 caracteres</small>
                    </div>

                    <!-- Archivo (Versión 1.0) -->
                    <div class="mb-3">
                        <label class="form-label">
                           Archivo - Versión 1.0
                            <span class="text-danger">*</span>
                        </label>
                        <input type="file"
                               class="form-control"
                               asp-for="ArchivoVersionado"
                               required
                               accept=".pdf,.docx,.xlsx,.dwg,.dxf,.rvt,.jpg,.jpeg,.png,.zip" />
                        <small class="text-muted">
                            Máximo 50 MB. Formatos: PDF, Word, Excel, CAD (DWG, DXF), Revit, Imágenes, ZIP
                        </small>
                    </div>

                    <!-- Comentarios de Versión -->
                    <div class="mb-3">
                        <label class="form-label">
                            Comentarios de la Versión
                        </label>
                        <textarea class="form-control"
                                  asp-for="ComentariosVersionInicial"
                                  rows="2"
                                  maxlength="1000"
                                  placeholder="Ej: Versión inicial del documento"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

