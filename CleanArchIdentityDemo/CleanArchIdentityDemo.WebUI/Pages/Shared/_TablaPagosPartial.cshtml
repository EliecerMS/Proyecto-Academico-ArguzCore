@using System.Linq
@model List<CleanArchIdentityDemo.Application.DTOs.PagoProveedorDto>

<table class="table table-striped align-middle">
    <thead class="table-light">
        <tr>
            <th>Proveedor</th>
            <th>Fecha</th>
            <th>Monto</th>
            <th>Concepto</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var pago in Model)
            {
                <tr>
                    <td>@pago.NombreProveedor</td>
                    <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                    <td>@pago.Monto.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                    <td>@pago.Descripcion</td>
                    <td>
                        <form method="post" asp-page-handler="VerRecibo" target="_blank" class="d-inline">
                            <input type="hidden" name="PagoId" value="@pago.IdPago" />
                            <button class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i> Ver comprobante
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">No se encontraron pagos a proveedores.</td>
            </tr>
        }
    </tbody>
</table>