@using System.Linq
@model List<CleanArchIdentityDemo.Application.DTOs.PagoProveedorDto>

<table class="table table-striped align-middle">
    <thead class="table-light">
        <tr>
            <th>Proveedor</th>
            <th>Fecha</th>
            <th>Monto</th>
            <th>Concepto</th>
            <th>Nombre archivo/documento subido</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var pago in Model)
            {
                <tr>
                    <td>@pago.NombreProveedor</td>
                    <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                    <td>@pago.Monto.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                    <td>@pago.Descripcion</td>
                    <td>
                        @if (!string.IsNullOrEmpty(@pago.RutaComprobante))
                        {
                            <strong>@pago.NombreDocumentoSubido</strong>
                        }
                        else
                        {
                            <span class="text-muted">Sin nombre</span>
                        }
                    </td>
                    <td>
                        <div class="container">
                            <div class="row">
                                <div class="col">
                                    <form method="post" asp-page-handler="VerRecibo" target="_blank" class="d-inline">
                                        <input type="hidden" name="PagoId" value="@pago.IdPago" />
                                        <button class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> Ver comprobante generado
                                        </button>
                                    </form>
                                </div>
                                <div class="col">
                                    @if (!string.IsNullOrEmpty(@pago.RutaComprobante))
                                    {
                                        <!-- Ver en nueva pestaña -->
                                        <a asp-page-handler="VerDocumento"
                                           asp-route-rutaComprobante="@pago.RutaComprobante"
                                           target="_blank"
                                           class="btn btn-secondary mb-2">
                                            <i class="fas fa-eye"></i> Ver factura subida
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No hay factura asociada</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">No se encontraron pagos a proveedores.</td>
            </tr>
        }
    </tbody>
</table>