@model List<CleanArchIdentityDemo.Application.DTOs.PuntoRestauracionDto>

<table class="table">
    <thead>
        <tr>
            <th>Nombre Punto</th>
            <th>Fecha Creacion</th>
            <th>Tipo Punto</th>
            <th>Fecha y hora mas antigua</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any() && Model.Count != 0)
        {
            @foreach (var backup in Model)
            {
                <tr>
                    <td>@backup.NombrePunto</td>
                    <td>
                        @if (backup.FechaCreacion.HasValue)
                        {
                            @backup.FechaCreacion.Value.LocalDateTime
                        }
                        else
                        {
                            <span>Desconocido</span>
                        }
                    </td>
                    <td>@backup.TipoPunto</td>
                    <td>@backup.FechaMasAntigua.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">No se encontraron backups automaticos o no se pudo conectar al servicio para consultar. También puede dirigirse a Azure Portal para consultar de ser necesario</td>
            </tr>
        }
    </tbody>
</table>