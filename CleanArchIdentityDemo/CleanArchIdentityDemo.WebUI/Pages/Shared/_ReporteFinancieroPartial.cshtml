@model CleanArchIdentityDemo.Application.DTOs.ReporteFinancieroDto

<div class="tab-pane fade show active" id="nav-ReporteFinanciero-tab" role="tabpanel" aria-labelledby="nav-ReporteFinanciero">

    <div class="d-flex justify-content-between align-items-center my-3">
    </div>

    @if (Model != null && Model.CostosEjecutados != null && Model.CostosEjecutados.Any())
    {
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Fecha</th>
                    <th>Descripción</th>
                    <th class="text-end">Costo ejecutado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CostosEjecutados)
                {
                    <tr>
                        <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@item.Descripcion</td>
                        <td class="text-end">₡@item.Monto.ToString("N2")</td>
                    </tr>
                }
            </tbody>

            <tfoot>
                <tr class="fw-semibold bg-light">
                    <td colspan="2" class="text-end">Total ejecutado:</td>
                    <td class="text-end @(Model.SobrepasoPresupuesto ? "text-danger fw-bold" : "fw-bold")">
                        ₡@Model.TotalEjecutado.ToString("N2")
                    </td>
                </tr>
            </tfoot>
        </table>

        <div class="mt-3">
            <p class="fw-semibold mb-1">
                Presupuesto planificado:
                <span class="fw-bold">₡@Model.PresupuestoPlanificado.ToString("N2")</span>
            </p>

            @if (Model.SobrepasoPresupuesto)
            {
                <p class="text-danger fw-bold mb-0">
                    Se sobrepasó el presupuesto en ₡@Model.MontoSobrepaso.ToString("N2")
                </p>
            }
            else
            {
                <p class="text-success fw-bold mb-0">
                    Dentro del presupuesto
                </p>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info mt-3 text-center py-4">
            No hay registros de costos ejecutados en el rango de fechas seleccionado.
        </div>
    }
</div>