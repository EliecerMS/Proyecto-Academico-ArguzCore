@page
@model CleanArchIdentityDemo.WebUI.Pages.Bodeguero.MaterialesModel
@{
    ViewData["Title"] = "Administración de Materiales";
}

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 25px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" id="successToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" id="errorToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true" id="warningToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["WarningMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-info border-0" role="alert" aria-live="assertive" aria-atomic="true" id="infoToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-info-circle me-2"></i>
                    @TempData["InfoMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-2 px-md-4">

<h2>Materiales</h2>

<nav>
    <div class="nav nav-tabs" id="nav-tab" role="tablist">
        <button class="nav-link active" id="nav-MaterialesBodega" data-bs-toggle="tab" data-bs-target="#nav-MaterialesBodega-tab" type="button" role="tab" aria-controls="nav-MaterialesBodega-tab" aria-selected="true">
            Materiales en Bodega
        </button>
        <button class="nav-link" id="nav-SolicitudesMaterial" data-bs-toggle="tab" data-bs-target="#nav-SolicitudesMaterial-tab" type="button" role="tab" aria-controls="nav-SolicitudesMaterial-tab" aria-selected="false">
            Solicitudes de material
        </button>
    </div>
</nav>

<div class="tab-content" id="nav-tabContent">
    <div class="tab-pane fade show active p-3" id="nav-MaterialesBodega-tab" role="tabpanel" aria-labelledby="nav-MaterialesBodega">
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-3">
                <h4 class="m-0 text-center text-sm-start">Materiales en Bodega</h4>
                <button class="btn btn-primary w-100 w-sm-auto" data-bs-toggle="modal" data-bs-target="#modalAgregarMaterial">
                    <i class="fas fa-plus me-1"></i> Nuevo Material
                </button>
            </div>


            <div class="table-responsive-sm">
                <table class="table table-striped table-bordered align-middle table-hover text-nowrap">

                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th class="d-none d-md-table-cell">Descripción</th>
                        <th class="text-end">Cantidad</th>
                        <th class="d-none d-lg-table-cell">Proveedor</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Materiales != null && Model.Materiales.Any())
                    {
                        @foreach (var m in Model.Materiales)
                        {
                            <tr>
                                <td>
                                    @m.NombreMaterial
                                     @if (m.CantidadDisponible == 0)
                                        {
                                            <span class="badge bg-danger ms-2">Stock agotado</span>
                                        }
                                            else if (m.CantidadDisponible <= 5)
                                            {
                                                <span class="badge bg-warning text-dark ms-2">Stock bajo</span>
                                            }                                
                                </td>
                                <td>@m.Tipo</td>
                                <td class="d-none d-md-table-cell">@m.Descripcion</td>
                                <td class="text-end">@m.CantidadDisponible</td>
                                <td class="d-none d-lg-table-cell">@m.ProveedorNombre</td>
                                <td class="text-center">
                                    <!-- botones de acción (implementar handlers en code-behind según sea necesario) -->
                                        <div class="btn-group btn-group-sm" role="group">
                                            <form method="post" asp-page-handler="EliminarMaterial" asp-route-IdMaterial="@m.IdMaterial" style="display:inline">
                                                <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                                    <i class="fas fa-trash"></i> Eliminar
                                                </button>
                                            </form>
                                            <button class="btn btn-sm btn-warning" title="Editar" data-bs-toggle="modal" data-bs-target="#modalEditarMaterial"
                                                    data-id="@m.IdMaterial"
                                                    data-nombre="@m.NombreMaterial"
                                                    data-tipo="@m.Tipo"
                                                    data-descripcion="@m.Descripcion"
                                                    data-cantidad="@m.CantidadDisponible"
                                                    data-proveedor="@m.ProveedorId">
                                                <i class="fas fa-edit"></i> Editar
                                            </button>
                                        </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">No hay materiales en bodega.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="tab-pane fade p-3" id="nav-SolicitudesMaterial-tab" role="tabpanel" aria-labelledby="nav-SolicitudesMaterial">
            <div class="table-responsive-sm">
                <table class="table table-striped table-bordered align-middle table-hover text-nowrap">

                <thead class="table-light">
                    <tr>
                        <th>Proyecto</th>
                        <th>ID Solicitud</th>
                        <th>Prioridad</th>
                        <th>Material</th>
                        <th class="text-end">Cantidad</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.MaterialesSolicitados != null && Model.MaterialesSolicitados.Any())
                    {
                        @foreach (var ms in Model.MaterialesSolicitados)
                        {
                            <tr>
                                <td>@ms.NombreProyecto</td>
                                <td>@ms.SolicitudId</td>
                                <td>@ms.Prioridad</td>
                                <td>@ms.NombreMaterial</td>
                                <td class="text-end">@ms.Cantidad</td>
                                <td class="text-center">
                                    @switch (ms.EstadoSolicitud)
                                    {
                                        case "Pendiente":
                                            <span class="badge rounded-pill bg-warning text-dark px-3 py-2">Pendiente</span>
                                            break;

                                        case "Aceptado":
                                            <span class="badge rounded-pill bg-success px-3 py-2">Aceptado</span>
                                            break;

                                        case "Rechazado":
                                            <span class="badge rounded-pill bg-danger px-3 py-2">Rechazado</span>
                                            break;

                                        default:
                                            <span class="badge rounded-pill bg-secondary px-3 py-2">@ms.EstadoSolicitud</span>
                                            break;
                                    }
                                </td>

                                <td>
                                    @if (ms.EstadoSolicitud != "Aceptado" && ms.EstadoSolicitud != "Rechazado")
                                    {
                                       <button class="btn btn-primary btn-sm atender-solicitud"
                                           data-id="@ms.SolicitudId"
                                           data-bs-toggle="modal"
                                           data-bs-target="#modalAtender">
                                                Atender Solicitud
                                            </button>
                                        }else
                                        {
                                            <span class="badge bg-secondary">Atendido</span>
                                        }
                                    </td>                                   
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">No hay materiales en bodega.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Atender Solicitud -->
    <div class="modal fade" id="modalAtender" tabindex="-1" aria-labelledby="modalAtenderLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-sm modal-md modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalAtenderLabel">Atender Solicitud</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formAtender">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="solicitudId" name="IdSolicitud" />
                    <div class="mb-3">
                        <label>Material</label>
                        <input type="text" class="form-control" id="nombreMaterial" readonly />
                    </div>
                    <div class="mb-3">
                        <label>Cantidad Solicitada</label>
                        <input  type="number" class="form-control" id="cantidad" readonly />
                    </div>
                    <div class="mb-3">
                        <label>Cantidad Disponible</label>
                        <input type="number" class="form-control" id="cantidadDisponible" readonly />
                    </div>
                        <div class="mb-3">
                            <label for="observaciones" class="form-label">Observaciones</label>
                            <textarea class="form-control" id="observaciones" name="Observaciones" rows="3" placeholder="Escribe tus observaciones..."></textarea required>
                        </div>

                    <div id="alertaCantidad" class="alert alert-danger d-none">
                        La cantidad solicitada supera la disponible.
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" id="btnRechazar">Rechazar</button>
                <button type="button" class="btn btn-success" id="btnAceptar">Aceptar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Agregar Material -->
<div class="modal fade"  id="modalAgregarMaterial" tabindex="-1" aria-labelledby="modalAgregarMaterialLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-sm modal-md modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="RegistrarMaterial">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalAgregarMaterialLabel">Nuevo Material</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" asp-for="NuevoMaterial.NombreMaterial" required />
                        <span class="text-danger" asp-validation-for="NuevoMaterial.NombreMaterial"></span> 
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" asp-for="NuevoMaterial.Tipo" required />
                        <span class="text-danger" asp-validation-for="NuevoMaterial.Tipo"></span>

                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea class="form-control" asp-for="NuevoMaterial.Descripcion" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cantidad disponible</label>
                        <input type="number" min="0" class="form-control" asp-for="NuevoMaterial.CantidadDisponible" required />
                        <span class="text-danger" asp-validation-for="NuevoMaterial.CantidadDisponible"></span>

                    </div>
                    <div class="mb-3">
                        <label class="form-label">Proveedor</label>
                        <span class="text-danger" asp-validation-for="NuevoMaterial.ProveedorId"></span>
                        <select class="form-select" asp-for="NuevoMaterial.ProveedorId">
                            <option value="0">-- Sin proveedor --</option>
                            @foreach (var p in Model.Proveedores)
                            {
                                <option value="@p.idProveedor">@p.NombreProveedor</option>
                            }
                        </select>
                        <span class="text-danger" asp-validation-for="NuevoMaterial.ProveedorId"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
                <div asp-validation-summary="All" class="text-danger"></div>

            </form>
            

        </div>
    </div>
</div>

<!-- Modal: Editar Material -->
<div class="modal fade" id="modalEditarMaterial" tabindex="-1" aria-labelledby="modalEditarMaterialLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-sm modal-md modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="Edit">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalEditarMaterialLabel">Editar Material</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <!-- Inputs ocultos -->
                    <input type="hidden" asp-for="EditadoMaterial.IdMaterial" id="IdMaterial" />
                    

                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" asp-for="EditadoMaterial.NombreMaterial" id="NombreMaterial" required />
                        <span class="text-danger" asp-validation-for="EditadoMaterial.NombreMaterial"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tipo</label>
                        <input class="form-control" asp-for="EditadoMaterial.Tipo" id="Tipo" required />
                        <span class="text-danger" asp-validation-for="EditadoMaterial.Tipo"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea class="form-control" asp-for="EditadoMaterial.Descripcion" id="Descripcion" rows="3"></textarea>
                        <span class="text-danger" asp-validation-for="EditadoMaterial.Descripcion"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Cantidad disponible</label>
                        <input type="number" min="0" class="form-control" asp-for="EditadoMaterial.CantidadDisponible" id="CantidadDisponible" required />
                        <span class="text-danger" asp-validation-for="EditadoMaterial.CantidadDisponible"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Proveedor</label>
                        <select class="form-select" asp-for="EditadoMaterial.ProveedorId" id="ProveedorSelect">
                            <option value="0">-- Sin proveedor --</option>
                            @foreach (var p in Model.Proveedores)
                            {
                                <option value="@p.idProveedor">@p.NombreProveedor</option>
                            }
                        </select>
                        <span class="text-danger" asp-validation-for="EditadoMaterial.ProveedorId"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
                <div asp-validation-summary="All" class="text-danger"></div>
            </form>
        </div>
    </div>
</div>


</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" /> @* Permite ver las validaciones de los campos del modal sin recargar la pagina *@
    <script>
        //script que hace funcionar las alertas
        document.addEventListener('DOMContentLoaded', function() {
            // Mostrar todos los toasts que existan
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            var toastList = toastElList.map(function(toastEl) {
                return new bootstrap.Toast(toastEl, {
                    autohide: true,
                    delay: 3000  // 3 segundos
                });
            });

            // Activar cada toast
            toastList.forEach(toast => toast.show());
        });



        // Mantener pestaña activa si se pasa por TempData
        document.addEventListener('DOMContentLoaded', function() {
            var tabActiva = '@TempData["TabActiva"]';
            if(tabActiva) {
                var triggerEl = document.querySelector(`#nav-${tabActiva}`);
                if(triggerEl){
                    var tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
        });

            // Cargar datos al abrir el modal Atender Solicitud
                $(document).on("click", ".atender-solicitud", function () {
            var id = $(this).data("id");
            console.log("🧠 Click atender, ID:", id);

            // Guardamos el ID en el input oculto ANTES de hacer el GET
            $("#solicitudId").val(id);

            $.get("/Bodeguero/Materiales?handler=ObtenerSolicitud&id=" + id, function (data) {
                if (data.error) {
                    alert(data.error);
                    return;
                }
                $("#nombreMaterial").val(data.nombreMaterial);
                $("#cantidad").val(data.cantidad);
                $("#cantidadDisponible").val(data.cantidadDisponible);
                $("#alertaCantidad").addClass("d-none");
            });
        });


                // Aceptar solicitud
                $("#btnAceptar").click(function () {
            var id = $("#solicitudId").val();
            var observaciones = $("#observaciones").val(); // <-- aquí capturamos
            var token = $('input[name="__RequestVerificationToken"]').val();

            console.log("Enviando ID:", id, "Observaciones:", observaciones);

            $.post("/Bodeguero/Materiales?handler=AceptarSolicitud",
                {
                    IdSolicitud: id,
                    Observaciones: observaciones, // <-- enviamos al servidor
                    __RequestVerificationToken: token
                },
                function (resp) {
                    if (resp.excede) {
                        $("#alertaCantidad").removeClass("d-none");
                    } else {
                        location.reload();
                    }
                }
            );
        });


        // Rechazar solicitud
        $("#btnRechazar").click(function () {
            var id = $("#solicitudId").val();
            var observaciones = $("#observaciones").val(); // <-- aquí capturamos
            var token = $('input[name="__RequestVerificationToken"]').val();
                   $.post("/Bodeguero/Materiales?handler=RechazarSolicitud",
                    { 
                        IdSolicitud: id,
                        Observaciones: observaciones,
                        __RequestVerificationToken: token
                    },
                function (resp) {
                    if (resp.excede) {
                        $("#alertaCantidad").removeClass("d-none");
                    } else {
                        location.reload();
                    }
                }
                   );
        }
        );

       // Cargar datos al abrir el modal Editar Material
        $('#modalEditarMaterial').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget); // Botón que activó el modal
            // Extraer datos de los atributos data-*
            var id = button.data('id');
            var nombre = button.data('nombre');
            var tipo = button.data('tipo');
            var descripcion = button.data('descripcion');
            var cantidad = button.data('cantidad');
            var proveedor = button.data('proveedor');
            // Actualizar el contenido del modal
            var modal = $(this);
            modal.find('#IdMaterial').val(id);
            modal.find('#NombreMaterial').val(nombre);
            modal.find('#Tipo').val(tipo);
            modal.find('#Descripcion').val(descripcion);
            modal.find('#CantidadDisponible').val(cantidad);
            modal.find('#ProveedorSelect').val(proveedor);
        });
    </script>
}