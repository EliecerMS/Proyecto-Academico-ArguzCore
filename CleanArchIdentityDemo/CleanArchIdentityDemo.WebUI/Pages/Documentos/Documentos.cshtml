@page
@model CleanArchIdentityDemo.WebUI.Pages.Documentos.DocumentosModel
@{
}

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 25px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" id="successToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" id="errorToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true" id="warningToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["WarningMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-primary border-0" role="alert" aria-live="assertive" aria-atomic="true" id="infoToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-info-circle me-2"></i>
                    @TempData["InfoMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>
 
<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Documentos</h1>
</div>

<nav>
    <div class="nav nav-tabs" id="nav-tab" role="tablist">
        <button class="nav-link" id="nav-DocumentoVersiones" data-bs-toggle="tab" data-bs-target="#nav-DocumentoVersiones-tab" type="button" role="tab" aria-controls="nav-DocumentoVersiones-tab" aria-selected="false">
            Documentos
        </button>
        <button class="nav-link" id="nav-GestionVersiones" data-bs-toggle="tab" data-bs-target="#nav-GestionVersiones-tab" type="button" role="tab" aria-controls="nav-GestionVersiones-tab" aria-selected="false">
            Subir documento/Gestionar Versiones
        </button>
        <button class="nav-link" id="nav-ContratosLaborales" data-bs-toggle="tab" data-bs-target="#nav-ContratosLaborales-tab" type="button" role="tab" aria-controls="nav-ContratosLaborales-tab" aria-selected="false">
            Contratos laborales
        </button>
    </div>
</nav>


<div class="tab-content" id="nav-tabContent">
    <div class="tab-pane fade show active" id="nav-DocumentoVersiones-tab" role="tabpanel" aria-labelledby="nav-DocumentoVersiones">
  <br />
  <form method="get" class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">

      <!-- Dropdown de categorías (un solo select con todas) -->
      <select class="form-select" style="width: 220px;" asp-for="Categoria" asp-items="Model.CategoriasSelect">
        <option value="">Seleccione una categoría...</option>
      </select>

      <!-- Barra de busqueda y botón de búsqueda -->
      <div class="input-group" style="width: 340px;">
        <span class="input-group-text bg-white border-end-0">
          <i class="fa-solid fa-magnifying-glass"></i>
        </span>
        <input type="text"
               class="form-control border-start-0"
               name="Q"
               value="@(Model.Q ?? "")"
               placeholder="Buscar por nombre o tipo de documento..." />
        <button type="submit" class="btn btn-primary">Buscar</button>
      </div>
    </div>

    <!-- Botón limpiar filtros -->
    <div>
      <a asp-page="/Documentos/Documentos" class="btn btn-link text-decoration-none">
        Limpiar filtros
      </a>
    </div>
  </form>
        <!-- Lista de resultados -->
        <div id="resultados">
            @await Html.PartialAsync("_ResultadosDocumentos", Model)
        </div>

    </div>


    <div class="tab-pane fade" id="nav-GestionVersiones-tab" role="tabpanel" aria-labelledby="nav-GestionVersiones">
        <br />
        <div class="container-fluid mt-4">
            <!-- Header con botones de acción -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h4 class="mb-0">
                                <i class="fas fa-folder-open text-primary"></i>
                                Documentos
                            </h4>
                                <small class="text-muted">
                                    @Model.Documentos.Count documento(s) |
                                
                               
                                    @Model.Documentos.Count(d => d.TipoDocumento == "Versionado") versionado(s) |
                                
                                
                                    @Model.Documentos.Count(d => d.TipoDocumento == "Simple") único(s)
                                
                            </small>
                        </div>
                        <div class="col-md-6 text-end">
                            <div class="btn-group" role="group" aria-label="Acciones de documentos">
                                <button type="button"
                                        class="btn btn-primary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalDocumentoVersionado"
                                        title="Crear documento con control de versiones">
                                    <i class="fas fa-layer-group"></i> Crear documento versionado
                                </button>
                                <button type="button"
                                        class="btn btn-info"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalNuevaVersion"
                                        title="Agregar versión a documento existente">
                                    <i class="fas fa-code-branch"></i> Añadir nueva versión
                                </button>
                                <button type="button"
                                        class="btn btn-success"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalDocumentoSimple"
                                        title="Subir documento único sin versiones">
                                    <i class="fas fa-file"></i> Crear documento único
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Listado de Documentos -->
            @if (!Model.Documentos.Any())
            {
                <div class="alert alert-info d-flex align-items-center" role="alert">
                    <i class="fas fa-info-circle fa-2x me-3"></i>
                    <div>
                        <h5 class="alert-heading mb-1">No hay documentos</h5>
                        <p class="mb-0">
                            Comience agregando un documento versionado o uno simple al proyecton, acá verá el historial de documentos simples o con versiones.
                        </p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var doc in Model.Documentos.OrderByDescending(d => d.FechaSubida))
                {
                    <div class="card mb-3 shadow-sm border-0">
                        <!-- Card Header con información del documento -->
                        <div class="card-header @(doc.TipoDocumento == "Versionado" ? "bg-primary text-white" : "bg-success text-white")">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h5 class="mb-1">
                                        @if (doc.TipoDocumento == "Versionado")
                                        {
                                            <i class="fas fa-layer-group"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-file"></i>
                                        }
                                        @doc.NombreDocumento

                                        @if (doc.TipoDocumento == "Versionado")
                                        {
                                            <span class="badge bg-light text-dark">@doc.VersionActual</span>
                                        }

                                        @if (!string.IsNullOrEmpty(doc.CategoriaDocumento))
                                        {
                                            <span class="badge bg-secondary">@doc.CategoriaDocumento</span>
                                        }
                                    </h5>
                                    @* @if (!string.IsNullOrEmpty(doc.Descripcion))
                                {
                                    <small class="d-block mt-1">
                                        @doc.Descripcion
                                    </small>
                                } *@
                                </div>
                                <div class="col-md-8">
                                    <h6 class="mb-1">
                                        Pertenece al proyecto <strong>@doc.NombreProyecto</strong>
                                    </h6>
                                </div>
                                <div class="col-md-4 text-end">
                                    @if (doc.TipoDocumento == "Versionado")
                                    {
                                        <span class="badge bg-light text-dark me-2 fs-6">
                                            @doc.TotalVersiones versión(es)
                                        </span>
                                        <button type="button"
                                                class="btn btn-sm btn-light"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalNuevaVersion"
                                                onclick="preseleccionarDocumento(@doc.IdDocumento)"
                                                title="Agregar nueva versión a este documento">
                                            <i class="fas fa-plus"></i> Nueva Versión
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark fs-6">
                                            <i class="fas fa-file"></i> Documento único
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Card Body con tabla de versiones o info del documento simple -->
                        <div class="card-body p-0">
                            @if (doc.TipoDocumento == "Versionado")
                            {
                                <!-- TABLA DE VERSIONES -->
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 8%;" class="text-center">Versión</th>
                                                <th style="width: 25%;">Archivo</th>
                                                <th style="width: 10%;" class="text-center">Tamaño</th>
                                                <th style="width: 15%;">Subido por</th>
                                                <th style="width: 12%;" class="text-center">Fecha</th>
                                                <th style="width: 20%;">Comentarios</th>
                                                <th style="width: 10%;" class="text-center">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var version in doc.Versiones.OrderByDescending(v => v.NumeroVersion))
                                            {
                                                <tr class="@(version.EsVersionActual ? "table-success" : "")">
                                                    <!-- Versión -->
                                                    <td class="text-center align-middle">
                                                        <strong class="d-block">@version.NumeroVersion</strong>
                                                        @if (version.EsVersionActual)
                                                        {
                                                            <span class="badge bg-success mt-1">
                                                                <i class="fas fa-check"></i> Actual
                                                            </span>
                                                        }
                                                    </td>

                                                    <!-- Archivo -->
                                                    <td class="align-middle">
                                                        <i class="fas @version.IconoArchivo fa-lg me-2"></i>
                                                        <span>@version.NombreArchivoOriginal</span>
                                                    </td>

                                                    <!-- Tamaño -->
                                                    <td class="text-center align-middle">
                                                        <span class="badge bg-light text-dark">
                                                            @version.TamanoFormateado
                                                        </span>
                                                    </td>

                                                    <!-- Subido por -->
                                                    <td class="align-middle">
                                                        <small>

                                                            @version.NombreSubidoPor
                                                        </small>
                                                    </td>

                                                    <!-- Fecha -->
                                                    <td class="text-center align-middle">
                                                        <small class="d-block">

                                                            @version.FechaSubida.ToString("dd/MM/yyyy")
                                                        </small>
                                                        <small class="text-muted">
                                                            <i class="fas fa-clock"></i>
                                                            @version.FechaSubida.ToString("HH:mm")
                                                        </small>
                                                    </td>

                                                    <!-- Comentarios -->
                                                    <td class="align-middle">
                                                        <small class="text-muted">
                                                            @if (!string.IsNullOrEmpty(version.Comentarios))
                                                            {

                                                                @version.Comentarios
                                                            }
                                                            else
                                                            {
                                                                <p>Sin comentarios</p>
                                                            }
                                                        </small>
                                                    </td>

                                                    <!-- Acciones -->
                                                    <td class="text-center align-middle">
                                                        <div class="btn-group btn-group-sm" role="group">
                                                            <!-- Descargar -->
                                                            <a asp-page-handler="DescargarVersion"
                                                               asp-route-idVersion="@version.IdVersion"
                                                               class="btn btn-outline-primary"
                                                               title="Descargar versión @version.NumeroVersion">
                                                                <i class="fas fa-download"></i>
                                                            </a>

                                                            <!-- Ver version en nueva pestaña -->
                                                            <a asp-page-handler="VerVersion"
                                                               asp-route-idVersion="@version.IdVersion"
                                                               target="_blank"
                                                               class="btn btn-outline-secondary"
                                                               title="Ver versión @version.NumeroVersion">
                                                                <i class="fas fa-eye"></i>
                                                            </a>

                                                            <!-- Marcar como actual (solo si NO es la actual) -->
                                                            @if (!version.EsVersionActual)
                                                            {
                                                                @if (!version.SubidoPor.Equals(Model.UsuarioId) && !Model.RolUsuario.Equals("ADMINISTRADOR", StringComparison.OrdinalIgnoreCase)) 

                                                                {

                                                                }
                                                                else
                                                                {
                                                                    <form method="post"
                                                                          asp-page-handler="MarcarComoActual"
                                                                          style="display:inline;"
                                                                          onsubmit="return confirm('¿Marcar @version.NumeroVersion como versión actual?\n\nEsto cambiará la versión de referencia del documento.');">
                                                                        <input type="hidden" name="idVersion" value="@version.IdVersion" />
                                                                        <button type="submit"
                                                                                class="btn btn-outline-success"
                                                                                title="Marcar como versión actual">
                                                                            <i class="fas fa-check"></i>
                                                                        </button>
                                                                    </form>

                                                                    <!-- Eliminar versión (solo si NO es la actual) -->
                                                                    <form method="post"
                                                                          asp-page-handler="EliminarVersion"
                                                                          style="display:inline;"
                                                                          onsubmit="return confirm('⚠️ ¿Eliminar la versión @version.NumeroVersion?\n\nEsta acción no se puede deshacer.\n\nEl archivo se eliminará del sistema.');">
                                                                        <input type="hidden" name="idVersion" value="@version.IdVersion" />
                                                                        <!-- <input type="hidden" name="sudidoPor" asp-for="SubidoPor" value="@version.SubidoPor" /> -->
                                                                        <button type="submit"
                                                                                class="btn btn-outline-danger"
                                                                                title="Eliminar esta versión">
                                                                            <i class="fas fa-trash"></i>
                                                                        </button>
                                                                    </form>
                                                                }  
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <!--  para documento simple (que no tiene versiones) -->
                                <div class="p-4">
                                    <div class="row align-items-center">
                                        <div class="col-md-8">
                                            <div class="d-flex align-items-center">
                                                <!-- Icono grande del tipo de archivo -->
                                                <div class="me-3">
                                                    <i class="fas @doc.IconoArchivo fa-4x"></i>
                                                </div>

                                                <!-- Información del archivo -->
                                                <div>
                                                    <h6 class="mb-2">
                                                        <strong>@doc.NombreArchivoOriginal</strong>
                                                    </h6>

                                                    <div class="mb-1">
                                                        <span class="badge bg-light text-dark me-2">
                                                            <i class="fas fa-hdd"></i>
                                                            Tamaño: @doc.TamanoFormateado
                                                        </span>
                                                        <span class="badge bg-light text-dark">
                                                            <i class="fas fa-file-code"></i>
                                                            @doc.TipoArchivo
                                                        </span>
                                                    </div>

                                                    <small class="text-muted d-block">

                                                        <strong>Subido por </strong>@doc.NombreCreadoPor
                                                    </small>
                                                    <small class="text-muted">
                                                        <i class="fas fa-calendar-alt"></i>
                                                        @doc.FechaSubida.ToString("dd/MM/yyyy HH:mm")
                                                    </small>

                                                    @if (!string.IsNullOrEmpty(doc.Descripcion))
                                                    {
                                                        <div class="mt-2">
                                                            <small class="text-muted">
                                                                <strong>
                                                                    Descripción:
                                                                </strong>
                                                                @doc.Descripcion
                                                            </small>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="mt-2">
                                                            <small class="text-muted">
                                                                <strong>
                                                                    Descripción:
                                                                </strong>
                                                                Sin descripción
                                                            </small>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Acciones para documento simple -->
                                        <div class="col-md-4 text-end">
                                            <div class="btn-group-vertical" role="group">
                                                <!-- Descargar -->
                                                <a asp-page-handler="DescargarDocumento"
                                                   asp-route-idDocumento="@doc.IdDocumento"
                                                   class="btn btn-primary mb-2">
                                                    <i class="fas fa-download"></i> Descargar
                                                </a>

                                                <!-- Ver en nueva pestaña -->
                                                <a asp-page-handler="VerDocumento"
                                                   asp-route-idDocumento="@doc.IdDocumento"
                                                   target="_blank"
                                                   class="btn btn-secondary mb-2">
                                                    <i class="fas fa-eye"></i> Ver en Navegador
                                                </a>
                                                @if (!doc.SubidoPor.Equals(Model.UsuarioId) && !Model.RolUsuario.Equals("ADMINISTRADOR", StringComparison.OrdinalIgnoreCase))
                                                {

                                                }
                                                else
                                                {
                                                    <!-- Eliminar documento -->
                                                    <form method="post"
                                                          asp-page-handler="EliminarDocumento"
                                                          class="d-inline"
                                                          onsubmit="return confirm('⚠️ ¿Eliminar el documento &quot;@doc.NombreDocumento&quot;?\n\nEsta acción no se puede deshacer.\n\nEl archivo se eliminará del sistema permanentemente.');">
                                                        <input type="hidden" name="idDocumento" value="@doc.IdDocumento" />
                                                        <button type="submit" class="btn btn-danger w-100">
                                                            <i class="fas fa-trash"></i> Eliminar Documento
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- CARD FOOTER - Información de Auditoría -->
                        <div class="card-footer text-muted bg-light">
                            <div class="row">
                                <div class="col-md-6">
                                    <small>
                                        <strong>Creado por:</strong> @doc.NombreCreadoPor
                                    </small>
                                    <br />
                                    <small>
                                        <strong>Fecha de creación:</strong> @doc.FechaSubida.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                </div>
                                <div class="col-md-6 text-end">
                                    @if (doc.FechaSubida != doc.UltimaModificacion)
                                    {
                                        <small>
                                            <strong>Última modificación:</strong>
                                            @doc.UltimaModificacion.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                        <br />
                                        @if (doc.TipoDocumento == "Versionado")
                                        {
                                            var ultimaVersion = doc.Versiones.OrderByDescending(v => v.NumeroVersion).FirstOrDefault();
                                            if (ultimaVersion != null)
                                            {
                                                <small class="text-muted">
                                                    Última versión subida por <strong>@ultimaVersion.NombreSubidoPor</strong>
                                                </small>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <small class="text-muted">
                                            <i class="fas fa-info-circle"></i>
                                            Sin modificaciones
                                        </small>
                                    }
                                </div>
                            </div>

                            <!-- Botón de eliminar documento completo (para versionados) -->
                            @if (!Model.RolUsuario.Equals("ADMINISTRADOR", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="mt-2 pt-2 border-top">
                                    <small class="text-muted">No tienes permisos para eliminar todas las versiones</small>
                                </div>
                            }
                            else
                            {
                                @if (doc.TipoDocumento == "Versionado")
                                {
                                    <div class="mt-2 pt-2 border-top">
                                        <form method="post"
                                              asp-page-handler="EliminarDocumento"
                                              class="d-inline float-end"
                                              onsubmit="return confirm('⚠️ ¿Eliminar COMPLETAMENTE el documento &quot;@doc.NombreDocumento&quot; y TODAS sus versiones (@doc.TotalVersiones)?\n\nEsta acción no se puede deshacer.\n\nTodos los archivos asociados se eliminarán del sistema.');">
                                            <input type="hidden" name="idDocumento" value="@doc.IdDocumento" />
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash-alt"></i> Eliminar archivo y todas sus versiones
                                            </button>
                                        </form>
                                    </div>
                                }
                            }

                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="tab-pane fade" id="nav-ContratosLaborales-tab" role="tabpanel" aria-labelledby="nav-ContratosLaborales">
        <div class="d-flex justify-content-between align-items-center my-3">
            <h2 class="h5 mb-0">Contratos laborales</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#registrarContratoModal">
                <i class="fa-solid me-1"></i> Registrar un contrato
            </button>
        </div>
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Empleado</th>
                    <th>Proyecto asignado</th>
                    <th>Fecha inicio</th>
                    <th>Fecha fin</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Contratos != null && Model.Contratos.Any())
                {
                    @foreach (var contrato in Model.Contratos)
                    {
                        var vencido = contrato.FechaFin.Date < DateTime.Today;
                        var porVencer = contrato.FechaFin.Date >= DateTime.Today && contrato.FechaFin.Date <= DateTime.Today.AddDays(15);
                        <tr>
                            <td>@contrato.Descripcion</td>
                            <td>@(string.IsNullOrEmpty(contrato.ProyectoNombre) ? "Sin proyecto" : contrato.ProyectoNombre)</td>
                            <td>@contrato.FechaInicio.ToString("yyyy-MM-dd")</td>
                            <td>@contrato.FechaFin.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (vencido)
                                {
                                    <span class="badge bg-danger">Contrato vencido</span>

                                }
                                else if (porVencer)
                                {
                                    <span class="badge bg-warning text-dark">Contrato próximo a vencerse</span>

                                }
                                else
                                {
                                    <span class="badge bg-success">Contrato activo</span>
                                }
                            </td>
                            <td class="text-end">
                                <button type="button"
                                        class="btn btn-sm btn-warning text-dark me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editarContratoModal"
                                        data-id="@contrato.IdContrato"
                                        data-descripcion="@contrato.Descripcion"
                                        data-proyectoid="@contrato.ProyectoId"
                                        data-proyectonombre="@contrato.ProyectoNombre"
                                        data-fechainicio="@contrato.FechaInicio.ToString("yyyy-MM-dd")"
                                        data-fechafin="@contrato.FechaFin.ToString("yyyy-MM-dd")"
                                        data-rutadocumento="@contrato.RutaDocumento">
                                    <i class="fa-solid fa-pen-to-square"></i> Editar
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-danger me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmDeleteContratoModal"
                                        data-id="@contrato.IdContrato"
                                        data-descripcion="@contrato.Descripcion">
                                    <i class="fa-solid fa-trash"></i> Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            No se encontraron contratos laborales registrados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

<!-- Modal: Crear documento con versiones-->
<div class="modal fade" id="modalDocumentoVersionado" tabindex="-1" aria-labelledby="modalVersionadoLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" enctype="multipart/form-data" asp-page-handler="CrearDocumentoVersionado" id="formDocumentoVersionado">
