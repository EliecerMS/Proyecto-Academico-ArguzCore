                    </div>


                    <!-- Nombre del Documento -->
                    <div class="mb-3">
                        <label class="form-label">
                            Nombre del Documento
                            <span class="text-danger">*</span>
                        </label>
                        <input type="text"
                               class="form-control"
                               asp-for="NombreDocumentoVersionado"
                               placeholder="Ej: Plano Estructural Principal"
