@section Scripts {
    <script>
        //script que hace funcionar las alertas
        document.addEventListener('DOMContentLoaded', function() {
            // Mostrar todos los toasts que existan
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            var toastList = toastElList.map(function(toastEl) {
                return new bootstrap.Toast(toastEl, {
                    autohide: true,
                    delay: 3000  // 3 segundos
                });
            });

            // Activar cada toast
            toastList.forEach(toast => toast.show());
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var tabActiva = '@TempData["TabActiva"]';
            if(tabActiva) {
                var triggerEl = document.querySelector(`#nav-${tabActiva}`);
                if(triggerEl){
                    var tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
        });
    </script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
          const modal = document.getElementById('editarContratoModal');
          if (!modal) return;

          modal.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            if (!btn) return;

            // Toma los datos del botón Editar
            const id          = btn.getAttribute('data-id') || '';
            const desc        = btn.getAttribute('data-descripcion') || '';
            const proyId      = btn.getAttribute('data-proyectoid') || '';
            const fIni        = btn.getAttribute('data-fechainicio') || '';
            const fFin        = btn.getAttribute('data-fechafin') || '';
            const ruta        = btn.getAttribute('data-rutadocumento') || '';

            // Mapea a los inputs del modal
            modal.querySelector('input[name="EditarContrato.IdContrato"]').value = id;
            modal.querySelector('input[name="EditarContrato.Descripcion"]').value = desc;
            modal.querySelector('input[name="EditarContrato.FechaInicio"]').value = fIni || new Date().toISOString().slice(0,10);
            modal.querySelector('input[name="EditarContrato.FechaFin"]').value    = fFin || new Date().toISOString().slice(0,10);

            const sel = modal.querySelector('select[name="EditarContrato.ProyectoId"]');
            if (sel) sel.value = proyId;

            const rutaInput = modal.querySelector('input[name="EditarContrato.RutaDocumento"]');
            if (rutaInput) rutaInput.value = ruta || '';
          });
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
          const delModal = document.getElementById('confirmDeleteContratoModal');
          if (!delModal) return;

          delModal.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            if (!btn) return;

            const id   = btn.getAttribute('data-id') || '';
            const desc = btn.getAttribute('data-descripcion') || '';

            delModal.querySelector('#Eliminar_IdContrato').value = id;
            delModal.querySelector('#Eliminar_Descripcion').textContent = desc;
          });
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
          // 1) Referencias
          const tabContenido = document.getElementById('nav-DocumentoVersiones-tab');
          if (!tabContenido) return;

          const form = tabContenido.querySelector('form'); // tu form de filtros
          if (!form) return;

          const sel = form.querySelector('select[name="Categoria"]');
          const q   = form.querySelector('input[name="Q"]');
          const cont = document.getElementById('resultados');

          async function cargarResultados() {
            const params = new URLSearchParams();
            if (sel && sel.value) params.set('categoria', sel.value);
            if (q && q.value)     params.set('q', q.value);

            const url = `${location.pathname}?handler=Buscar&${params.toString()}`;
            const resp = await fetch(url, { headers: { 'X-Requested-With': 'fetch' } });
            const html = await resp.text();
            cont.innerHTML = html;

            // Actualiza la URL sin recargar (para compartir / back-forward)
            const newUrl = `${location.pathname}?${params.toString()}`;
            history.replaceState(null, '', newUrl);
          }

          // 2) Interceptar submit del botón "Buscar"
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            cargarResultados();
          });

          // 3) Buscar al cambiar la categoría
          sel?.addEventListener('change', cargarResultados);

          // 4) Enter dentro de la caja de búsqueda
          q?.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
              e.preventDefault();
              cargarResultados();
            }
          });

          // 5) “Limpiar filtros” por AJAX si existe el enlace
          const limpiar = tabContenido.querySelector('a[href$="/Documentos/Documentos"]');
          limpiar?.addEventListener('click', (e) => {
            e.preventDefault();
            if (sel) sel.value = '';
            if (q)   q.value = '';
            cargarResultados();
          });
        });
    </script>

}