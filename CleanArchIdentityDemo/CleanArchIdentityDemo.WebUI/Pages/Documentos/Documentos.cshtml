                    <!-- Descripción -->
                    <div class="mb-3">
                        <label class="form-label">
                            Descripción
                        </label>
                        <textarea class="form-control"
                                  asp-for="DescripcionDocumentoVersionado"
                                  rows="2"
                                  maxlength="500"
                                  placeholder="Descripción general del documento (opcional)"></textarea>
