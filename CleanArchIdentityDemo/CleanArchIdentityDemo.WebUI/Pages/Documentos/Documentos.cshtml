                        <label class="form-label">
                            Comentarios sobre los Cambios
                            <span class="text-danger">*</span>
                        </label>
                        <textarea class="form-control"
                                  asp-for="ComentariosNuevaVersion"
                                  rows="3"
                                  required
                                  maxlength="1000"
                                  placeholder="Ej: Corrección de medidas en sección B, actualización de especificaciones técnicas, revisión de materiales"></textarea>
                        <small class="text-muted">
                            <strong>Importante:</strong>
                            Describa claramente los cambios realizados en esta versión para mantener un historial comprensible
                        </small>
                    </div>

                    <!-- Info adicional -->
                    <div class="alert alert-info mb-0">
                        <i class="fas fa-info-circle"></i>
                        <strong>Numeración automática:</strong> El número de versión se incrementará automáticamente (ej: 1.0 → 1.1 → 2.0)
                    </div>
