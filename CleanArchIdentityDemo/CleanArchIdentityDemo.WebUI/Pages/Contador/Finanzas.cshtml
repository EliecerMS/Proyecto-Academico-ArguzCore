@page
@model CleanArchIdentityDemo.WebUI.Pages.Contador.FinanzasModel
@{
    ViewData["Title"] = "Administración de Finanzas";
}

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 25px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" id="successToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" id="errorToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true" id="warningToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["WarningMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-primary border-0" role="alert" aria-live="assertive" aria-atomic="true" id="infoToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-info-circle me-2"></i>
                    @TempData["InfoMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>

<h2>Finanzas</h2>

<nav>
    <div class="nav nav-tabs" id="nav-tab" role="tablist">
        <button class="nav-link" id="nav-GestionProveedor" data-bs-toggle="tab" data-bs-target="#nav-GestionProveedor-tab" type="button" role="tab" aria-controls="nav-GestionProveedor-tab" aria-selected="false">
            Gestion de proveedores
        </button>
        <button class="nav-link" id="nav-PagosProveedor" data-bs-toggle="tab" data-bs-target="#nav-PagosProveedor-tab" type="button" role="tab" aria-controls="nav-PagosProveedor-tab" aria-selected="false">
            Pagos por proveedor
        </button>
        <button class="nav-link" id="nav-GastosEjecutados" data-bs-toggle="tab" data-bs-target="#nav-GastosEjecutados-tab" type="button" role="tab" aria-controls="nav-GastosEjecutados-tab" aria-selected="false">
            Gastos ejecutados
        </button>
    </div>
</nav>



<div class="tab-content" id="nav-tabContent">

    <div class="tab-pane fade" id="nav-GestionProveedor-tab" role="tabpanel" aria-labelledby="nav-GestionProveedor">
        <div class="d-flex justify-content-end my-4">
            <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#registrarProveedor">
                <i class="fas fa-plus"></i> Registrar proveedor
            </button>
        </div>
        <div class="table-responsive">
            <!-- Tabla de proveedores -->
            <table class="table table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th>Contacto</th>
                        <th class="align-content-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Proveedores != null && Model.Proveedores.Any())
                    {
                        @foreach (var proveedor in Model.Proveedores)
                        {
                            <tr>
                                <td>@proveedor.NombreProveedor</td>
                                <td>@proveedor.Contacto</td>
                                <td>
                                    <div class="container">
                                        <div class="row">
                                            <div class="col">
                                                <!-- Contenido para columna accion 1 -->
                                                <button class="btn btn-sm btn-warning"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editarProveedorModal"
                                                        data-id="@proveedor.IdProveedor"
                                                        data-nombre="@proveedor.NombreProveedor"
                                                        data-contacto="@proveedor.Contacto">
                                                    <i class="fas fa-edit"></i> Editar
                                                </button>
                                            </div>
                                            <div class="col">
                                                <!-- Contenido para columna accion 2 -->
                                                <button type="button" class="btn btn-sm btn-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#modalEliminacionProveedor"
                                                        data-id="@proveedor.IdProveedor"
                                                        data-nombreProveedor="@proveedor.NombreProveedor">
                                                    <i class="fa-solid fa-trash"></i> Eliminar
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center">No hay proveedores registrados.</td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>


    <div class="tab-pane fade" id="nav-PagosProveedor-tab" role="tabpanel" aria-labelledby="nav-PagosProveedor">
        <!--- Ajustar el siguiente botón con lo necesario para abrir un modal y registrar un nuevo pago a proveedor, luego borrar este comentario -->
        <div class="d-flex justify-content-end my-4">
            <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#registrarPagoModal">
                <i class="fas fa-plus"></i> Registrar pago
            </button>
        </div>


        <div class="row mb-4">
            <div class="col-md-3">
                <label class="form-label">Filtrar por proveedor</label>
                <select id="filtroProveedor" class="form-control">
                    <option value="">Todos</option>
                    @foreach (var proveedor in Model.Proveedores)
                    {
                        <option value="@proveedor.IdProveedor">@proveedor.NombreProveedor</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label for="fechaInicio" class="form-label">Fecha inicio</label>
                <input type="date" class="form-control" id="fechaInicio">
            </div>
            <div class="col-md-3">
                <label for="fechaFin" class="form-label">Fecha fin</label>
                <input type="date" class="form-control" id="fechaFin">
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="button" class="btn btn-primary w-100" onclick="filtrarPagos()">
                    <i class="fas fa-filter"></i> Filtrar
                </button>
            </div>
        </div>


        <!--- Tabla de pagos a proveedores --->
        <div class="position-relative">
            <div class="table-responsive" id="tablaPagosContainer">
                <partial name="_TablaPagosPartial" model="Model.PagosProveedores" />
            </div>

            <div id="loadingSpinner" class="text-center py-5" style="display: none;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <p class="mt-2 text-muted">Cargando resultados...</p>
            </div>
        </div>
    </div>

    <!--Gastos ejecutados -->
    <div class="tab-pane fade" id="nav-GastosEjecutados-tab" role="tabpanel" aria-labelledby="nav-GastosEjecutados">
        <br></br>
       
        <div class="row justify-content-between">
            <div class="col-4">
                Gastos ejecutados por proyecto
            </div>
            <div class="col-4">
                <!-- Botón para abrir modal -->
                    <button class="btn btn-primary btn-sm"
                            data-bs-toggle="modal"
                            data-bs-target="#registrarCostoModal">
                        <i class="fa-solid fa-plus"></i> Agregar gasto ejecutado
                    </button>
            </div>
        </div>
         <br></br>
        <!-- Tabla de proyectos -->
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Proyecto</th>
                        <th>Presupuesto (₡)</th>
                        <th>Fecha final propuesta</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Proyectos != null && Model.Proyectos.Any())
                    {
                        @foreach (var proyecto in Model.Proyectos)
                        {
                            <tr>
                                <td>
                                        @proyecto.Nombre
                                </td>

                                <td>@proyecto.Presupuesto.ToString("N2")</td>
                                <td>@proyecto.FechaFinalPropuesta.ToShortDateString()</td>
                                <td>
                                    @if (proyecto.IdEstadoProyecto == 1)
                                    {
                                        <p class="badge bg-primary">@proyecto.EstadoProyecto</p>

                                    }
                                    @if (proyecto.IdEstadoProyecto == 2)
                                    {
                                        <p class="badge bg-success">@proyecto.EstadoProyecto</p>
                                    }
                                    @if (proyecto.IdEstadoProyecto == 3)
                                    {
                                        <p class="badge bg-secondary">@proyecto.EstadoProyecto</p>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="container">
                                        <div class="row">
                                            <div class="col">
                                                <button class="btn btn-sm btn-info"
                                                        onclick="mostrarGastosProyecto(@proyecto.IdProyecto, '@proyecto.Nombre')">
                                                    <i class="fa-solid fa-eye"></i> Ver gastos ejecutados
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No hay proyectos registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Contenedor donde se carga la tabla parcial -->
        <div id="contenedorGastosProyecto" class="card mt-4" style="display:none;">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 id="tituloProyecto" class="mb-0 fw-bold text-primary">Gastos ejecutados</h6>
                <button class="btn btn-sm btn-outline-secondary" onclick="cerrarGastosProyecto()">Cerrar</button>
            </div>
            <div id="tablaGastosProyecto" class="card-body p-0">
            </div>
        </div>
    </div>

</div>

<!--- Modal registrar proveedor --->
<div class="modal fade" id="registrarProveedor" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="RegistrarProveedor">
                <div class="modal-header">
                    <h5 class="modal-title">Registrar proveedor</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <!-- Errores generales -->
                    
                    <div class="mb-3">
                        <label asp-for="Proveedor.NombreProveedor" class="form-label">Nombre</label>
                        <input asp-for="Proveedor.NombreProveedor" required
                               minlength="3"
                               maxlength="100"
                               class="form-control @(ViewData.ModelState["Proveedor.NombreProveedor"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="Proveedor.NombreProveedor" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Proveedor.Contacto" class="form-label">Contacto</label>
                        <input asp-for="Proveedor.Contacto" required
                               class="form-control @(ViewData.ModelState["Proveedor.Contacto"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="Proveedor.Contacto" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Registrar</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Editar proveedor -->
<div class="modal fade" id="editarProveedorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="EditarProveedor">
                <div class="modal-header">
                    <h5 class="modal-title">Editar proveedor</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="ProveedorEditado.IdProveedor" />
                    <div class="mb-3">
                        <label asp-for="ProveedorEditado.NombreProveedor" class="form-label">Nombre</label>
                        <input asp-for="ProveedorEditado.NombreProveedor" required
                               minlength="3"
                               maxlength="100" 
                               class="form-control @(ViewData.ModelState["ProveedorEditado.NombreProveedor"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="ProveedorEditado.NombreProveedor" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProveedorEditado.Contacto" class="form-label">Contacto</label>
                        <input asp-for="ProveedorEditado.Contacto" required 
                               class="form-control @(ViewData.ModelState["ProveedorEditado.Contacto"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="ProveedorEditado.Contacto" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Guardar</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Confirmar eliminación proveedor -->
<div class="modal fade" id="modalEliminacionProveedor" tabindex="-1" aria-labelledby="modalEliminacionProveedorLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="EliminarProveedor">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalEliminarProveedor">Confirmar eliminación</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>¿Seguro que desea eliminar este proveedor, todos los registros asociados a el se perderán?</p>
                    <p><strong id="nombreProveedor"></strong></p>

                    <!-- valores ocultos -->
                    <input type="hidden" asp-for="IdProveedor" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Confirmar eliminación</button>
                </div>
            </form>
        </div>
    </div>
</div>
<!-- Modal: Registrar pago -->
<div class="modal fade" id="registrarPagoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="RegistrarPago">
                <div class="modal-header">
                    <h5 class="modal-title">Registrar pago a proveedor</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Proveedor</label>
                        <select asp-for="PagoSeleccionado.ProveedorId" class="form-select" required>
                            <option value="">Seleccione un proveedor</option>
                            @foreach (var proveedor in Model.Proveedores)
                            {
                                <option value="@proveedor.IdProveedor">@proveedor.NombreProveedor</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Proyecto</label>
                        <select asp-for="PagoSeleccionado.ProyectoId" class="form-select" required>
                            <option value="">Seleccione un proyecto</option>
                            @foreach (var proyecto in Model.Proyectos)
                            {
                                <option value="@proyecto.IdProyecto">@proyecto.Nombre</option>
                            }
                        </select>


                    </div>

                    <div class="mb-3">
                        <label class="form-label">Monto (₡)</label>
                        <input asp-for="PagoSeleccionado.Monto" type="number" step="0.01" min="1" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Fecha de pago</label>
                        <input asp-for="PagoSeleccionado.FechaPago" type="date" class="form-control" required
                               value="@DateTime.Today.ToString(" yyyy-MM-dd")" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea asp-for="PagoSeleccionado.Descripcion" class="form-control" rows="2" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Registrar</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>
<!-- Modal: Registrar costo ejecutado -->
<div class="modal fade" id="registrarCostoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="RegistrarCosto" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">Registrar gasto ejecutado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <!-- Proyecto -->
                    <div class="mb-3">
                        <label class="form-label">Proyecto</label>
                        <select asp-for="CostoSeleccionado.ProyectoId" class="form-select" id="selectProyectoCosto" required>
                            <option value="">Seleccione un proyecto</option>
                            @foreach (var proyecto in Model.Proyectos)
                            {
                                <option value="@proyecto.IdProyecto">@proyecto.Nombre</option>
                            }
                        </select>
                    </div>

                    <!-- Nombre del Documento -->
                    <div class="mb-3">
                        <label class="form-label">
                            Concepto
                            <span class="text-danger">*</span>
                        </label>
                        <input type="text"
                               class="form-control"
                               asp-for="NombreDocumentoSimple"
                               placeholder="Ej: Factura #001 - Proveedor ABC"
                               required
                               maxlength="255" />
                    </div>

                    <!-- Categoría -->
                    <div class="mb-3">
                        <label class="form-label">Categoría de gasto</label>
                        <select asp-for="CostoSeleccionado.CategoriaGasto" class="form-select" required>
                            <option value="">Seleccione una categoría</option>
                            <option value="Materiales">Materiales</option>
                            <option value="Mano de obra">Mano de obra</option>
                            <option value="Equipos">Equipos</option>
                            <option value="Transporte">Transporte</option>
                            <option value="Servicios">Servicios</option>
                            <option value="Otros">Otros</option>
                        </select>

                    </div>

                    <!-- Monto -->
                    <div class="mb-3">
                        <label class="form-label">Monto (₡)</label>
                        <input asp-for="CostoSeleccionado.Monto" type="number" step="0.01" class="form-control" placeholder="Ingrese el monto del gasto" required />
                    </div>

                    <!-- Fecha -->
                    <div class="mb-3">
                        <label class="form-label">Fecha</label>
                        <input asp-for="CostoSeleccionado.Fecha" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                    </div>

                    <!-- Descripción -->
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea asp-for="CostoSeleccionado.Descripcion" class="form-control" rows="2" placeholder="Detalles sobre el gasto..." required></textarea>
                    </div>

                    <!-- Archivo -->
                    <div class="mb-3">
                        <label class="form-label">
                            Archivo
                            <span class="text-danger">*</span>
                        </label>
                        <input type="file"
                               class="form-control"
                               asp-for="ArchivoSimple"
                               required
                               accept=".pdf,.docx,.xlsx,.jpg,.jpeg,.png,.zip" />
                        <small class="text-muted">

                            Máximo 50 MB. Formatos: PDF, Word, Excel, Imágenes, ZIP
                        </small>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Registrar</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Editar gasto ejecutado -->
<div class="modal fade" id="editarCostoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="EditarCosto" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title">Editar gasto ejecutado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <!-- ID oculto -->
                    <input type="hidden" asp-for="CostoSeleccionado.IdCosto" id="editar_IdCosto" />

                    <!-- Proyecto -->
                    <div class="mb-3">
                        <label class="form-label">Proyecto</label>
                        <select asp-for="CostoSeleccionado.ProyectoId" class="form-select" id="editar_ProyectoId" required>
                            <option value="">Seleccione un proyecto</option>
                            @foreach (var proyecto in Model.Proyectos)
                            {
                                <option value="@proyecto.IdProyecto">@proyecto.Nombre</option>
                            }
                        </select>
                    </div>

                    <!-- Categoría -->
                    <div class="mb-3">
                        <label class="form-label">Categoría de gasto</label>
                        <select asp-for="CostoSeleccionado.CategoriaGasto" id="editar_CategoriaGasto" class="form-select" required>
                            <option value="">Seleccione una categoría</option>
                            <option value="Materiales">Materiales</option>
                            <option value="Mano de obra">Mano de obra</option>
                            <option value="Equipos">Equipos</option>
                            <option value="Transporte">Transporte</option>
                            <option value="Servicios">Servicios</option>
                            <option value="Otros">Otros</option>
                        </select>

                    </div>

                    <!-- Monto -->
                    <div class="mb-3">
                        <label class="form-label">Monto (₡)</label>
                        <input asp-for="CostoSeleccionado.Monto" type="number" step="0.01" id="editar_Monto" class="form-control" required />
                    </div>

                    <!-- Fecha -->
                    <div class="mb-3">
                        <label class="form-label">Fecha</label>
                        <input asp-for="CostoSeleccionado.Fecha" type="date" id="editar_Fecha" class="form-control" required />
                    </div>

                    <!-- Descripción -->
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea asp-for="CostoSeleccionado.Descripcion" id="editar_Descripcion" class="form-control" rows="2" required></textarea>
                    </div>

                    <!-- Comprobante -->
                    <div class="mb-3">
                        <label class="form-label">Nuevo comprobante (opcional)</label>
                        <input name="ArchivoComprobante" type="file" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                        <small class="text-muted">Si no se selecciona archivo, se conserva el comprobante actual.</small>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Guardar cambios</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Eliminar gasto ejecutado -->
<div class="modal fade" id="eliminarCostoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="EliminarCosto">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">Eliminar gasto ejecutado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro de que desea eliminar el gasto ejecutado de la categoría <strong id="nombreCategoria"></strong>?</p>
                    <input type="hidden" asp-for="CostoSeleccionado.IdCosto" id="eliminar_IdCosto" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        //script que hace funcionar las alertas
        document.addEventListener('DOMContentLoaded', function() {
            // Mostrar todos los toasts que existan
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            var toastList = toastElList.map(function(toastEl) {
                return new bootstrap.Toast(toastEl, {
                    autohide: true,
                    delay: 3000  // 3 segundos
                });
            });

            // Activar cada toast
            toastList.forEach(toast => toast.show());
        });
        // Llenar modal Editar proveedor con datos del botón pulsado
        var editUserModal = document.getElementById('editarProveedorModal');
        editUserModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var nombre = button.getAttribute('data-nombre');
            var contacto = button.getAttribute('data-contacto');

            document.getElementById('ProveedorEditado_IdProveedor').value = id;
            document.getElementById('ProveedorEditado_NombreProveedor').value = nombre;
            document.getElementById('ProveedorEditado_Contacto').value = contacto;
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var tabActiva = '@TempData["TabActiva"]';
            if(tabActiva) {
                var triggerEl = document.querySelector(`#nav-${tabActiva}`);
                if(triggerEl){
                    var tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
        });
    </script>
    <!-- JavaScript -->
    <script>
        async function filtrarPagos() {
            const idProveedor = document.getElementById('filtroProveedor').value;
            const fechaInicio = document.getElementById('fechaInicio').value;
            const fechaFin = document.getElementById('fechaFin').value;

            const params = new URLSearchParams({
                handler: 'FiltrarPagos',
                idProveedor,
                fechaInicio,
                fechaFin
            });

            const tabla = document.getElementById('tablaPagosContainer');
            const spinner = document.getElementById('loadingSpinner');

            try {
                // Mostrar loading
                tabla.style.display = 'none';
                spinner.style.display = 'block';

                // Fetch data
                const response = await fetch(`?${params.toString()}`, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (!response.ok) throw new Error('Error en la petición');

                // Actualizar tabla
                tabla.innerHTML = await response.text();

            } catch (error) {
                console.error('Error:', error);
                tabla.innerHTML = '<div class="alert alert-danger">Error al filtrar pagos</div>';
            } finally {
                // Siempre ocultar spinner y mostrar tabla
                spinner.style.display = 'none';
                tabla.style.display = 'block';
            }
        }
        //Mostrar costo ejecutado
        async function mostrarGastosProyecto(idProyecto, nombreProyecto) {
               try {
                   const response = await fetch(`?handler=VerGastosPorProyecto&idProyecto=${idProyecto}`, {
                       method: 'GET',
                       headers: { 'X-Requested-With': 'XMLHttpRequest' }
                   });

                   if (!response.ok) throw new Error("Error al obtener los gastos ejecutados.");

                   const html = await response.text();
                   document.getElementById('tablaGastosProyecto').innerHTML = html;
                   document.getElementById('tituloProyecto').innerText = `Gastos ejecutados para: ${nombreProyecto}`;
                   document.getElementById('contenedorGastosProyecto').style.display = 'block';
               } catch (error) {
                   console.error(error);
                   alert("No se pudieron cargar los gastos ejecutados del proyecto.");
               }
           }

           function cerrarGastosProyecto() {
               document.getElementById('contenedorGastosProyecto').style.display = 'none';
               document.getElementById('tablaGastosProyecto').innerHTML = '';
           }
    </script>
    <script>
        var modalEliminacionProveedor = document.getElementById('modalEliminacionProveedor');
        modalEliminacionProveedor.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var nombreProveedor = button.getAttribute('data-nombreProveedor');

            document.getElementById('IdProveedor').value = id;
            document.getElementById('nombreProveedor').innerText = nombreProveedor;
        });
        //Script para editar costo ejucutado
        var editarCostoModal = document.getElementById('editarCostoModal');
        editarCostoModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;

            document.getElementById('editar_IdCosto').value = button.getAttribute('data-id');
            document.getElementById('editar_ProyectoId').value = button.getAttribute('data-proyecto');
            document.getElementById('editar_CategoriaGasto').value = button.getAttribute('data-categoria');
            document.getElementById('editar_Monto').value = button.getAttribute('data-monto');
            document.getElementById('editar_Fecha').value = button.getAttribute('data-fecha');
            document.getElementById('editar_Descripcion').value = button.getAttribute('data-descripcion');
        });

        //Script para elimar costo ejecutado
        var eliminarCostoModal = document.getElementById('eliminarCostoModal');
        eliminarCostoModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;

            document.getElementById('eliminar_IdCosto').value = button.getAttribute('data-id');
            document.getElementById('nombreCategoria').innerText = button.getAttribute('data-categoria');
        });
    </script>

}