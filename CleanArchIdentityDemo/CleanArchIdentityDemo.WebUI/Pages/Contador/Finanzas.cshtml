@page
@model CleanArchIdentityDemo.WebUI.Pages.Contador.FinanzasModel
@{
    ViewData["Title"] = "Administración de Finanzas";
}

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 25px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" id="successToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" id="errorToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true" id="warningToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["WarningMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-info border-0" role="alert" aria-live="assertive" aria-atomic="true" id="infoToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-info-circle me-2"></i>
                    @TempData["InfoMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>

<h2>Finanzas</h2>

<nav>
    <div class="nav nav-tabs" id="nav-tab" role="tablist">
        <button class="nav-link" id="nav-GestionProveedor" data-bs-toggle="tab" data-bs-target="#nav-GestionProveedor-tab" type="button" role="tab" aria-controls="nav-GestionProveedor-tab" aria-selected="false">
            Gestion de proveedores
        </button>
        <button class="nav-link" id="nav-PagosProveedor" data-bs-toggle="tab" data-bs-target="#nav-PagosProveedor-tab" type="button" role="tab" aria-controls="nav-PagosProveedor-tab" aria-selected="false">
            Pagos por proveedor
        </button>
        <button class="nav-link" id="nav-GastosEjecutados" data-bs-toggle="tab" data-bs-target="#nav-GastosEjecutados-tab" type="button" role="tab" aria-controls="nav-GastosEjecutados-tab" aria-selected="false">
            Gastos ejecutados
        </button>
    </div>
</nav>



<div class="tab-content" id="nav-tabContent">

    <div class="tab-pane fade" id="nav-GestionProveedor-tab" role="tabpanel" aria-labelledby="nav-GestionProveedor">
        Contenido del tab Gestion de proveedores (Este ttab es nuevo y Eliecer es encargado de este tab)
    </div>


    <div class="tab-pane fade" id="nav-PagosProveedor-tab" role="tabpanel" aria-labelledby="nav-PagosProveedor">
        Pagos por proveedor
        <!--- Ajustar el siguiente botón con lo necesario para abrir un modal y registrar un nuevo pago a proveedor, luego borrar este comentario -->
        <div class="d-flex justify-content-end mb-4">
            <button class="btn btn-success" id="registrarPagoBtn">
                <i class="fas fa-plus"></i> Registrar pago
            </button>
        </div>


        <div class="row mb-4">
            <div class="col-md-3">
                <label for="filtroProveedor" class="form-label">Filtrar por proveedor</label>
                <select class="form-select" id="filtroProveedor">
                    <option value="">Todos los proveedores</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="fechaInicio" class="form-label">Fecha inicio</label>
                <input type="date" class="form-control" id="fechaInicio" placeholder="dd/mm/aaaa">
            </div>
            <div class="col-md-3">
                <label for="fechaFin" class="form-label">Fecha fin</label>
                <input type="date" class="form-control" id="fechaFin" placeholder="dd/mm/aaaa">
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-primary w-100" id="filtrarPagosBtn">
                    <i class="fas fa-filter"></i> Filtrar
                </button>
            </div>
        </div>


        <!--- Tabla de pagos a proveedores --->
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Proveedor</th>
                        <th>Fecha</th>
                        <th>Monto</th>
                        <th>Concepto</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.PagosProveedores != null && Model.PagosProveedores.Any())
                    {
                        @foreach (var pago in Model.PagosProveedores)
                        {
                            <tr>
                                <td>@pago.NombreProveedor</td>
                                <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                <td>@pago.Monto.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                                <td>@pago.Descripcion</td>
                                <td>
                                    <form method="post" asp-page-handler="VerRecibo" target="_blank" class="d-inline">
                                        <input type="hidden" name="PagoId" value="@pago.IdPago" />
                                        <button class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> Ver comprobante
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                           <td colspan="4" class="text-center">No se encontraron pagos a proveedores.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="tab-pane fade" id="nav-GastosEjecutados-tab" role="tabpanel" aria-labelledby="nav-GastosEjecutados">
        Contenido del tab Gastos Ejecutados
    </div>
</div>





@section Scripts {
    <script>
        //script que hace funcionar las alertas
        document.addEventListener('DOMContentLoaded', function() {
            // Mostrar todos los toasts que existan
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            var toastList = toastElList.map(function(toastEl) {
                return new bootstrap.Toast(toastEl, {
                    autohide: true,
                    delay: 3000  // 3 segundos
                });
            });

            // Activar cada toast
            toastList.forEach(toast => toast.show());
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var tabActiva = '@TempData["TabActiva"]';
            if(tabActiva) {
                var triggerEl = document.querySelector(`#nav-${tabActiva}`);
                if(triggerEl){
                    var tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
        });
    </script>

}