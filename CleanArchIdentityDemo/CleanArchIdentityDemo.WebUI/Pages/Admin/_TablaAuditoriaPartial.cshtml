@model CleanArchIdentityDemo.Application.DTOs.ResultadoPaginado<CleanArchIdentityDemo.Application.DTOs.AuditoriaDto>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Usuario</th>
            <th>Módulo</th>
            <th>Acción</th>
            <th>Detalles de Datos</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Items.Any())
        {
            foreach (var item in Model.Items)
            {
                var collapseId = $"collapse_{item.IdAuditoria}";
                <tr>
                    <td>@item.FechaHora.ToString("g")</td>
                    <td>@item.NombreUsuario</td>
                    <td>@item.Modulo</td>
                    <td>@item.Accion</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@collapseId"
                                aria-expanded="false"
                                aria-controls="@collapseId">
                            Ver Detalles
                        </button>

                        <div class="collapse mt-2" id="@collapseId">
                            <div class="card border-info shadow-sm">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <h6 class="text-danger fw-bold">Dato Anterior</h6>
                                            <div class="audit-box border border-danger-subtle">
                                                @if (!string.IsNullOrWhiteSpace(item.DatoAnterior))
                                                {
                                                    <dl class="row">
                                                        @foreach (var line in item.DatoAnterior.Split('\n').Where(l => !string.IsNullOrWhiteSpace(l)))
                                                        {
                                                            var parts = line.Split(':', 2);
                                                            if (parts.Length == 2)
                                                            {
                                                                <dt class="col-sm-9 fw-semibold">@parts[0].Trim()</dt>
                                                                <dd class="col-sm-8">@parts[1].Trim()</dd>
                                                            }
                                                        }

                                                    </dl>
                                                }
                                                else
                                                {
                                                    <p class="text-muted fst-italic">No contiene datos</p>
                                                }
                                            </div>
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <h6 class="text-success fw-bold">Dato Nuevo</h6>
                                            <div class="audit-box border border-success-subtle">
                                                @if (!string.IsNullOrWhiteSpace(item.DatoNuevo))
                                                {
                                                    <dl class="row">
                                                        @foreach (var line in item.DatoNuevo.Split('\n').Where(l => !string.IsNullOrWhiteSpace(l)))
                                                        {
                                                            var parts = line.Split(':', 2);
                                                            if (parts.Length == 2)
                                                            {
                                                                <dt class="col-sm-9 fw-semibold">@parts[0]</dt>
                                                                <dd class="col-sm-8">@parts[1].Trim()</dd>
                                                            }
                                                        }
                                                    </dl>
                                                }
                                                else
                                                {
                                                    <p class="text-muted fst-italic">No contiene datos</p>
                                                }
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">No se encontraron registros.</td>
            </tr>
        }
    </tbody>

</table>



