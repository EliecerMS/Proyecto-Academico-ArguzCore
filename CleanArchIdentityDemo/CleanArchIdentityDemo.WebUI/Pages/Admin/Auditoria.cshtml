@page
@model CleanArchIdentityDemo.WebUI.Pages.Admin.AuditoriaModel
@{
}

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 25px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" id="successToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" id="errorToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true" id="warningToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["WarningMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-primary border-0" role="alert" aria-live="assertive" aria-atomic="true" id="infoToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-info-circle me-2"></i>
                    @TempData["InfoMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>

<div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Auditoria</h1>
</div>

<nav>
    <div class="nav nav-tabs" id="nav-tab" role="tablist">
        <button class="nav-link" id="nav-Acciones" data-bs-toggle="tab" data-bs-target="#nav-Acciones-tab" type="button" role="tab" aria-controls="nav-Acciones-tab" aria-selected="false">
            Acciones de usuarios
        </button>
    </div>
</nav>


<div class="tab-content" id="nav-tabContent">
    <div class="tab-pane fade" id="nav-Acciones-tab" role="tabpanel" aria-labelledby="nav-Acciones">
        <br />
        <div class="row justify-content-between">
            <div class="col-4">
                Filtrar acciones
            </div>
        </div>
        <br />
        <!-- Componentes del filtrado para tener una base que pueda le sirva -->
        <div class="row mb-4">
            <!-- Usuario -->
            <div class="col-md-3">
                <label class="form-label">Usuario</label>
                <select id="usuario" class="form-control">
                    <option value="">Todos</option>
                    @foreach (var usuario in Model.RegistrosAuditoria
                                        .Select(r => r.NombreUsuario)
                                        .Where(u => !string.IsNullOrEmpty(u))
                                        .Distinct())
                    {
                        <option value="@usuario">@usuario</option>
                    }
                </select>
            </div>

            <!-- Acción -->
            <div class="col-md-3">
                <label class="form-label">Acción</label>
                <select id="accion" class="form-control">
                    <option value="">Todos</option>
                    @foreach (var accion in Model.RegistrosAuditoria
                                        .Select(r => r.Accion)
                                        .Where(a => !string.IsNullOrEmpty(a))
                                        .Distinct())
                    {
                        <option value="@accion">@accion</option>
                    }
                </select>
            </div>

            <!-- Módulo -->
            <div class="col-md-3">
                <label class="form-label">Módulo</label>
                <select id="modulo" class="form-control">
                    <option value="">Todos</option>
                    @foreach (var modulo in Model.RegistrosAuditoria
                                        .Select(r => r.Modulo)
                                        .Where(m => !string.IsNullOrEmpty(m))
                                        .Distinct())
                    {
                        <option value="@modulo">@modulo</option>
                    }
                </select>
            </div>

            <!-- Fechas -->
            <div class="col-md-3">
                <label class="form-label">Desde</label>
                <input type="date" class="form-control" id="fechaInicio">
            </div>
            <div class="col-md-3">
                <label class="form-label">Hasta</label>
                <input type="date" class="form-control" id="fechaFin">
            </div>

            <!-- Botón filtrar -->
            <div class="col-md-3 d-flex align-items-end">
                <button type="button" id="btnFiltrar" class="btn btn-primary w-100">
                    <i class="fas fa-filter"></i> Filtrar
                </button>
            </div>
        </div>

        <!-- Botón descargar PDF -->
        <div class="text-end mb-3">
            <button id="btnDescargarExcel" class="btn btn-success">
                <i class="bi bi-file-earmark-excel"></i> Descargar Excel
            </button>
        </div>


        <!-- Aca una base de la tabla que carga los resultados del filtro, diseñar como el prototipo -->
        <div id="tablaAuditoriaContainer">
            @await Html.PartialAsync("_TablaAuditoriaPartial", Model.RegistrosAuditoria)
        </div>

    </div>

    <div class="tab-pane fade" id="nav-GenerarReporte-tab" role="tabpanel" aria-labelledby="nav-GenerarReporte">
        <br />
        <div class="row justify-content-between">
            <div class="col-4">
                Accesos por módulo
            </div>
        </div>
        <br />
        <div class="col-4">
            <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#">
                <i class="fa-solid fa-file-pdf"></i> Descargar reporte
            </button>
        </div>

        <!-- Componentes del filtrado para tener una base que pueda le sirva -->
        <div class="col-4">
            <label for="" class="form-label">Seleccionar modulo</label>
            <select id="" class="form-control">
                <option value="">Todos</option>
                @* @foreach (var proveedor in Model.Proveedores)
                    {
                        <option value="@proveedor.IdProveedor">@proveedor.NombreProveedor</option>
                    } *@
            </select>
        </div>
        <div class="col-4">
            <label for="" class="form-label">Filtrar por usuario</label>
            <select id="" class="form-control">
                <option value="">Todos</option>
                @* @foreach (var proveedor in Model.Proveedores)
                    {
                        <option value="@proveedor.IdProveedor">@proveedor.NombreProveedor</option>
                    } *@
            </select>
        </div>
        <br />
        <!-- Aca una base de la tabla que carga los resultados del filtro, diseñar como el prototipo -->
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Colum 1</th>
                    <th>Colum 2</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        Colum 1
                    </td>
                    <td>
                        Colum 2
                    </td>
                </tr>
            </tbody>
        </table>

    </div>
</div>



@section Scripts {
    <script>
        //script que hace funcionar las alertas
        document.addEventListener('DOMContentLoaded', function() {
            // Mostrar todos los toasts que existan
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            var toastList = toastElList.map(function(toastEl) {
                return new bootstrap.Toast(toastEl, {
                    autohide: true,
                    delay: 3000  // 3 segundos
                });
            });

            // Activar cada toast
            toastList.forEach(toast => toast.show());
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var tabActiva = '@TempData["TabActiva"]';
            if(tabActiva) {
                var triggerEl = document.querySelector(`#nav-${tabActiva}`);
                if(triggerEl){
                    var tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
        });

        //FIltros de auditoria
        document.getElementById("btnFiltrar").addEventListener("click", function () {
            const usuario = document.getElementById("usuario").value;
            const accion = document.getElementById("accion").value;
            const modulo = document.getElementById("modulo").value;
            const desde = document.getElementById("fechaInicio").value;
            const hasta = document.getElementById("fechaFin").value;

            fetch(`?handler=Filtrar&usuario=${usuario}&accion=${accion}&modulo=${modulo}&desde=${desde}&hasta=${hasta}`, {
                method: "GET",
                headers: {
                    "X-Requested-With": "XMLHttpRequest"
                }
            })
                .then(response => response.text())
                .then(html => {
                    document.getElementById("tablaAuditoriaContainer").innerHTML = html;
                })
                .catch(err => console.error("Error al filtrar:", err));
        });

           // Descargar Excel   
        document.getElementById("btnDescargarExcel").addEventListener("click", function () {
            const usuario = document.getElementById("usuario").value;
            const accion = document.getElementById("accion").value;
            const modulo = document.getElementById("modulo").value;
            const desde = document.getElementById("fechaInicio").value;
            const hasta = document.getElementById("fechaFin").value;

            // Redirige a la ruta que genera el Excel
            window.location.href = `?handler=DescargarExcel&usuario=${usuario}&accion=${accion}&modulo=${modulo}&desde=${desde}&hasta=${hasta}`;
        });
    

    </script>
}