@page
@model CleanArchIdentityDemo.WebUI.Pages.Admin.AdminModel
@{
    ViewData["Title"] = "Administración de Usuarios";
}

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 25px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" id="successToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true" id="errorToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true" id="warningToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["WarningMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="toast align-items-center text-white bg-info border-0" role="alert" aria-live="assertive" aria-atomic="true" id="infoToast">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-info-circle me-2"></i>
                    @TempData["InfoMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
</div>

<h2>Administración de Usuarios</h2>

<nav>
    <div class="nav nav-tabs" id="nav-tab" role="tablist">
        <button class="nav-link" id="nav-Usuarios" data-bs-toggle="tab" data-bs-target="#nav-Usuarios-tab" type="button" role="tab" aria-controls="nav-Usuarios-tab" aria-selected="false">
            Usuarios
        </button>
        <button class="nav-link" id="nav-Respaldos" data-bs-toggle="tab" data-bs-target="#nav-Respaldos-tab"
                type="button" role="tab" aria-controls="nav-Respaldos-tab" aria-selected="false">
            Respaldos
        </button>
    </div>
</nav>


<div class="tab-content" id="nav-tabContent">

    <div class="tab-pane fade show active" id="nav-Usuarios-tab" role="tabpanel" aria-labelledby="nav-Usuarios">
        <br />
        <div class="row justify-content-between">
            <div class="col-4">
                Lista de usuarios
            </div>
            <div class="col-4">
                <!-- Botón para abrir modal Crear Usuario -->
                <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#createUserModal">
                    Crear Usuario
                </button>
            </div>
        </div>
        <div>
            <!-- Tabla de Usuarios -->
            <table class="table table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Email</th>
                        <th>Nombre Completo</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th class="align-content-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users != null && Model.Users.Any())
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.Email</td>
                                <td>@user.NombreCompleto</td>
                                <td>@user.Role</td>
                                <td>
                                    @if(!user.Activo)
                                    {
                                        <small class="badge bg-danger">Desactivado</small>
                                    }
                                    else
                                    {
                                        <small class="badge bg-success">Activo</small>
                                    }
                                </td>
                                <td>
                                    <div class="container">
                                        <div class="row">
                                            <div class="col">
                                                <!-- Contenido para columna accion 1 -->
                                                <button class="btn btn-sm btn-warning"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editUserModal"
                                                        data-id="@user.Id"
                                                        data-email="@user.Email"
                                                        data-nombre="@user.NombreCompleto"
                                                        data-activo="@user.Activo"
                                                        data-rol="@user.Role">
                                                    <i class="fas fa-edit"></i> Editar
                                                </button>
                                            </div>
                                            @if (user.Activo)
                                            {
                                                <div class="col">
                                                    <!-- Contenido para columna accion 2 -->
                                                    <form method="post" asp-page-handler="Delete">
                                                        <input type="hidden" name="IdUsuario" value="@user.Id" />
                                                        <button class="btn btn-sm btn-danger">
                                                            <i class="fas fa-ban"></i> Desactivar
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="col">
                                                    <!-- Contenido para columna accion 2 -->
                                                    <form method="post" asp-page-handler="Activate">
                                                        <input type="hidden" name="IdUsuario" value="@user.Id" />
                                                        <button class="btn btn-sm btn-info">
                                                            <i class="fa-solid fa-circle-check"></i> Activar
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                            
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center">No hay usuarios disponibles.</td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>

    <div class="tab-pane fade" id="nav-Respaldos-tab" role="tabpanel" aria-labelledby="nav-Respaldos">
        <br />
        <div class="row justify-content-between">
            <div class="col-4">
                <h2>Gestión de Backups</h2>
            </div>
            <div class="col-4">
                <!-- Botón para abrir modal Crear Usuario -->
                <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#crearBackupModal">
                    Crear backup
                </button>
            </div>
        </div>
        <div class="container-fluid mt-4">
            <!-- Información PITR -->
            <div class="row">
                <div>
                    <div class="card">
                        <div class="card-header bg-info text-white">
                            <h5>Backups Automáticos (PITR)</h5>
                        </div>
                        <div class="card-body">
                            <p>
                                <strong>Retención:</strong> 7 días (configurable hasta 35 días)
                            </p>
                            
                            <p class="text-muted mb-0">
                                <small>
                                    Los backups automáticos se realizan cada 5-10 minutos. Solo se muestran los registros de estos puntos de restauración.
                                    La única acción a tomar para estos puntos de restauración es unicamente restaurarlos, y para hacerlo solamente es posible ingresando al Azure Portal.
                                </small>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!--- Tabla de backups automaticos --->
            <div class="position-relative">
                <div class="table-responsive" id="tablaBackupsAutomaticosContainer">
                    <partial name="_TablaBackupsPITR" model="Model.PuntosRestauracion" />
                </div>

                <div id="loadingSpinner" class="text-center py-5" style="display: none;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2 text-muted">Cargando datos de backups automaticos...</p>
                </div>
            </div>

            <!-- Backups Manuales -->
            @* <div class="card">
                <div class="card-header">
                    <h5>Backups Manuales Disponibles</h5>
                </div>
                <div class="card-body">
                    @if (!Model.BackupsManuales.Any())
                    {
                        <p class="text-muted">No hay backups manuales creados</p>
                    }
                    else
                    {
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Archivo</th>
                                    <th>Fecha</th>
                                    <th>Tamaño</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var backup in Model.BackupsManuales)
                                {
                                    <tr>
                                        <td>@backup.NombreArchivo</td>
                                        <td>@backup.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@backup.TamanoFormateado</td>
                                        <td>
                                            <a href="@backup.UrlDescarga"
                                               class="btn btn-sm btn-primary"
                                               target="_blank">
                                                <i class="fas fa-download"></i> Descargar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div> *@
        </div>
    </div>

</div>



<!-- Modal Crear Usuario -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Create">
                <div class="modal-header">
                    <h5 class="modal-title">Crear Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Email</label>
                        <input asp-for="NewUser.Email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>Nombre Completo</label>
                        <input asp-for="NewUser.NombreCompleto" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>Rol</label>
                        <select asp-for="NewUser.Role" class="form-control">
                            @foreach (var rol in Model.Roles)
                            {
                                <option value="@rol.NombreRol">@rol.NombreRol</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label>Contraseña</label>
                        <input asp-for="NewUser.Password" type="password" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Crear</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Editar Usuario -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Edit">
                <div class="modal-header">
                    <h5 class="modal-title">Editar Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditedUser.Id" />
                    <input type="hidden" asp-for="EditedUser.Activo" />
                    <div class="mb-3">
                        <label>Email</label>
                        <input asp-for="EditedUser.Email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>Nombre Completo</label>
                        <input asp-for="EditedUser.NombreCompleto" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>Rol</label>
                        <select asp-for="EditedUser.Role" class="form-control">
                            @foreach (var rol in Model.Roles)
                            {
                                <option value="@rol.NombreRol">@rol.NombreRol</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label>Nueva contraseña</label>
                        <input asp-for="EditedUser.Password" type="password" class="form-control" placeholder="De no dar un contraseña se mantendra la actual" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Guardar</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Crear Backup Manual -->
<div class="modal fade" id="crearBackupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Crear backup</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Nombre del Backup</label>
                        <input type="text"
                               class="form-control"
                               asp-for="NombreBackup"
                               placeholder="backup_pre_actualizacion"
                               required>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary"> <i class="fas fa-save"></i> Crear Backup </button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Mostrar todos los toasts que existan
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            var toastList = toastElList.map(function(toastEl) {
                return new bootstrap.Toast(toastEl, {
                    autohide: true,
                    delay: 3000  // 3 segundos
                });
            });

            // Activar cada toast
            toastList.forEach(toast => toast.show());

         const respaldosButton = document.getElementById('nav-Respaldos');

        if (respaldosButton) {
            respaldosButton.addEventListener('click', cargarBackupsAutomaticos);
        }

        });
        // Llenar modal Editar con datos del botón pulsado
        var editUserModal = document.getElementById('editUserModal');
        editUserModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var email = button.getAttribute('data-email');
            var nombre = button.getAttribute('data-nombre');
            var rol = button.getAttribute('data-rol');
            var activo = button.getAttribute('data-activo');

            document.getElementById('EditedUser_Id').value = id;
            document.getElementById('EditedUser_Email').value = email;
            document.getElementById('EditedUser_NombreCompleto').value = nombre;
            document.getElementById('EditedUser_Role').value = rol;
            document.getElementById('EditedUser_Activo').value = activo;
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var tabActiva = '@TempData["TabActiva"]';
            if(tabActiva) {
                var triggerEl = document.querySelector(`#nav-${tabActiva}`);
                if(triggerEl){
                    var tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
        });
    </script>
    <script>
        async function cargarBackupsAutomaticos() {
          const handlerName = 'CargarBackupsAutomaticos';

             const tabla = document.getElementById('tablaBackupsAutomaticosContainer');
             const spinner = document.getElementById('loadingSpinner');

             try {
                         // Mostrar loading
                         tabla.style.display = 'none';
                         spinner.style.display = 'block';

                         // Fetch data
                          const response = await fetch(`?handler=${handlerName}`, {
                            method: 'GET',
                            // Headers son opcionales pero útiles para depuración
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });

                         if (!response.ok) throw new Error('Error en la petición');

                         // Actualizar tabla
                         tabla.innerHTML = await response.text();

                     } catch (error) {
                         console.error('Error:', error);
                         tabla.innerHTML = '<div class="alert alert-danger">Error al obtener los datos de backups automaticos</div>';
                     } finally {
                         // Siempre ocultar spinner y mostrar tabla
                         spinner.style.display = 'none';
                         tabla.style.display = 'block';
                     }
         }
    </script>
    
}
